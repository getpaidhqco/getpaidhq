// Usage-event store schema — a SEPARATE database (getpaidhq_usage / USAGE_DATABASE_URL)
// so the high-volume meter_events firehose scales and is retained independently of the
// operational DB. Only meter_events lives here; meters (billable_metrics), customers,
// and prices stay in schemas/app. There is no cross-DB relation to Org — org_id is a
// plain scoping column.
//
// Push with: pnpm prisma:usage:push  (falls back to operational DB only if you point
// USAGE_DATABASE_URL there; otherwise set it to the getpaidhq_usage DSN).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MeterEvent {
  orgId String @map("org_id")
  id    String @default(cuid())

  // Optional ids are NULL when absent (never ""): "no value" stays unambiguous and the
  // dedup index / customer match key off real values, not an empty-string sentinel.
  customerId         String? @map("customer_id")
  externalCustomerId String? @map("external_customer_id")
  metricCode         String  @map("metric_code")
  subscriptionId     String? @map("subscription_id")
  externalId         String? @map("external_id")

  metadata  Json?
  value     Decimal  @default(0) @db.Decimal(38, 9)
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@id([orgId, id])
  // Write-time dedup: resends share an external_id. external_id is NULL when absent,
  // and Postgres unique indexes treat NULLs as distinct, so a plain unique works —
  // absent-id events are never deduped, real external_ids are.
  @@unique([orgId, externalId])
  @@index([orgId, customerId, metricCode, timestamp])
  @@index([orgId, externalCustomerId, metricCode, timestamp])
  @@map("meter_events")
}
