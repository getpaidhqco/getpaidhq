generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("GPHQ_USAGE_DATABASE_URL")
}

// The raw usage events that are received from the usage API.
// Enriched with business context from the CloudEvent subject.
model UsageEvent {
  orgId String @map("org_id")
  id    String // CloudEvent id field

  // Business context (enriched from CloudEvent subject)
  subscriptionId     String @map("subscription_id")
  subscriptionItemId String @map("subscription_item_id")
  meterId            String @map("meter_id")

  // CloudEvents v1.0 fields
  specVersion String   @map("spec_version")
  type        String   @map("type")
  eventId     String   @map("event_id") // CloudEvent id field
  time        DateTime @map("time") @db.Timestamptz
  source      String   @map("source")
  subject     String   @map("subject")
  data        Json     @map("data")

  // Audit
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz

  @@id([orgId, id])
  @@map("usage_events")
}

model UsageProcessingStatus {
  orgId              String    @map("org_id")
  subscriptionItemId String    @map("subscription_item_id")
  billingPeriod      String    @map("billing_period") // Format: "2025-07"
  totalQuantity      Decimal   @default(0) @map("total_quantity") @db.Decimal(15, 4)
  totalAmount        BigInt    @default(0) @map("total_amount")
  eventCount         Int       @default(0) @map("event_count")
  processed          Boolean   @default(false)
  processedAt        DateTime? @map("processed_at") @db.Timestamptz
  invoiceId          String?   @map("invoice_id")
  firstEventTime     DateTime  @map("first_event_time") @db.Timestamptz
  lastEventTime      DateTime  @map("last_event_time") @db.Timestamptz
  lastUpdated        DateTime  @default(now()) @map("last_updated") @db.Timestamptz

  @@id([orgId, subscriptionItemId, billingPeriod])
  @@map("usage_processing_status")
}

model UsageEventLog {
  id                 String   @id @default(cuid())
  timestamp          DateTime @default(now()) @db.Timestamptz
  orgId              String   @map("org_id")
  eventType          String   @map("event_type") // 'recorded', 'processed', 'corrected', 'refunded'
  subscriptionId     String?  @map("subscription_id")
  subscriptionItemId String?  @map("subscription_item_id")
  customerId         String?  @map("customer_id")
  invoiceId          String?  @map("invoice_id")
  amount             BigInt?
  quantity           Decimal? @db.Decimal(15, 4)
  eventCount         Int?     @map("event_count")
  billingPeriod      String?  @map("billing_period")
  triggeredBy        String?  @map("triggered_by") // User or system identifier
  reason             String?
  metadata           Json?

  @@map("usage_event_log")
}
