// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgStatus {
  active
  trial
  demo
  inactive
  deleted
}

model ApiKey {
  orgId     String   @map("org_id")
  id        String   @default(cuid())
  // Optional human-readable label set at creation time (e.g. "ci-deploy",
  // "billing-webhook"). Purely metadata — auth uses the keyHash only.
  name      String?
  // keyHash is HMAC-SHA256(API_KEY_PEPPER, raw key) hex-encoded.
  // The raw key is shown to the user exactly once at creation and
  // never stored anywhere. Lookup uses the hash directly so DB
  // compromise without the pepper does not grant API access.
  keyHash   String   @map("key_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@unique([keyHash])
  @@map("api_keys")
}

model Org {
  id              String            @id
  country         String
  status          OrgStatus         @default(active)
  name            String
  timezone        String            @default("UTC")
  metadata        Json?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  users           UserOrg[]
  Session         Session[]
  Variant         Variant[]
  Price           Price[]
  Order           Order[]
  Customer        Customer[]
  Subscription    Subscription[]
  Payment         Payment[]
  Setting         Setting[]
  OrderItem       OrderItem[]
  ApiKey          ApiKey[]
  MetadataStore   MetadataStore[]
  Invoice         Invoice[]
  InvoiceLineItem InvoiceLineItem[]
  BillableMetric  BillableMetric[]

  @@map("orgs")
}

model Invoice {
  orgId String @map("org_id")
  id    String @default(cuid())

  // Referenced by id (no Prisma relation) — the spine entities; gorm handles loads.
  subscriptionId String @map("subscription_id")
  customerId     String @map("customer_id")
  orderId        String @map("order_id")

  status   InvoiceStatus
  currency String
  subtotal Int           @default(0)
  total    Int           @default(0)

  cycle       Int
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")

  lineItems InvoiceLineItem[]

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@unique([orgId, subscriptionId, cycle]) // one invoice per cycle (mirrors the billing RunKey)
  @@map("invoices")
}

enum InvoiceStatus {
  draft
  open
  paid
  unpaid
  void
}

model InvoiceLineItem {
  orgId String @map("org_id")
  id    String @default(cuid())

  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [orgId, invoiceId], references: [orgId, id], onDelete: Cascade)

  priceId     String              @map("price_id")
  kind        InvoiceLineItemKind
  description String              @default("")

  quantity   Decimal @db.Decimal(38, 9)
  unitAmount Decimal @map("unit_amount") @db.Decimal(38, 9)
  total      Int     @default(0)

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("invoice_line_items")
}

enum InvoiceLineItemKind {
  base
  usage
}

model Gateway {
  orgId  String  @map("org_id")
  id     String
  name   String
  pspId  String  @map("psp_id")
  active Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@id([orgId, id])
  @@map("gateways")
}

model Setting {
  orgId     String @map("org_id")
  parentId  String @map("parent_id")
  id        String
  valueType String @map("value_type")
  value     Json

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, parentId, id])
  @@map("settings")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  UserOrg   UserOrg[]

  @@map("users")
}

model UserOrg {
  userId String @map("user_id")
  orgId  String @map("org_id")

  user User @relation(fields: [userId], references: [id])
  org  Org  @relation(fields: [orgId], references: [id])

  role Role @default(user)

  @@id([userId, orgId])
  @@map("user_orgs")
}

enum Role {
  owner
  admin
  user
}

model Cart {
  orgId String @map("org_id")
  id    String @default(cuid())

  data     Json?
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  order     Order[]

  @@id([orgId, id])
  @@map("carts")
}

enum ProductStatus {
  active
  archived
}

model Product {
  orgId String @map("org_id")
  id    String @default(cuid())

  name        String
  description String?

  // Lifecycle. `archived` products are hidden from default listings and not
  // sellable, but preserved in historic data. archivedAt is audit metadata,
  // set on archive and cleared on unarchive. See ADR 0005.
  status     ProductStatus @default(active)
  archivedAt DateTime?     @map("archived_at")

  metadata Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  Variant   Variant[]

  @@id([orgId, id])
  // Backs the default listing: WHERE org_id = ? AND status IN (...) ORDER BY
  // created_at. The (org_id, id) primary key index doesn't cover status.
  @@index([orgId, status, createdAt])
  @@map("products")
}

model Variant {
  orgId String @map("org_id")
  id    String @default(cuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [orgId, productId], references: [orgId, id], onDelete: Cascade)

  name        String
  description String?

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  Price     Price[]

  org       Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  OrderItem OrderItem[]

  @@id([orgId, id])
  @@map("variants")
}

model Price {
  orgId String @map("org_id")
  id    String @default(cuid())

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [orgId, variantId], references: [orgId, id], onDelete: Cascade)

  category PriceCategory
  scheme   PriceScheme

  label String?

  currency  String
  unitPrice Int    @map("unit_price")

  cycles             Int?
  billingInterval    BillingInterval? @map("billing_interval")
  billingIntervalQty Int?             @map("billing_interval_qty")

  trialInterval    BillingInterval? @map("trial_interval")
  trialIntervalQty Int?             @map("trial_interval_qty")

  minPrice       Int? @map("min_price")
  suggestedPrice Int? @map("suggested_price")

  taxCode          String? @map("tax_code")
  billableMetricId String? @map("billable_metric_id")
  tiers            Json?

  // Metered filter: scopes this price to one slice of its meter (a value of one of the
  // meter's filters). filterField unset = whole meter; set with no value = catch-all.
  // See docs/internal/usage-filters-and-groups.md.
  filterField String? @map("filter_field")
  filterValue String? @map("filter_value")

  // Proration switches for prices on weighted_sum carry-over meters; inert otherwise.
  // See docs/internal/billing-model/seat-billing/mapping.md §2.3.
  prorateOnIncrease Boolean @default(false) @map("prorate_on_increase")
  creditOnDecrease  Boolean @default(false) @map("credit_on_decrease")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("prices")
}

enum PriceCategory {
  one_time
  subscription
  free
  variable
}

enum PriceScheme {
  fixed
  tiered
  volume
  graduated
}

enum BillingInterval {
  none
  minute
  hour
  day
  week
  month
  year
}

model Session {
  orgId String @map("org_id")
  id    String @default(cuid())

  cartId String? @map("cart_id")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("sessions")
}

model Order {
  orgId      String      @map("org_id")
  id         String      @default(cuid())
  customerId String      @map("customer_id")
  customer   Customer    @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Restrict)
  status     OrderStatus

  reference String

  sessionId String @map("session_id")

  currency String
  total    Int

  metadata Json

  items         OrderItem[]
  subscriptions Subscription[]
  payments      Payment[]

  cartId String @map("cart_id")
  cart   Cart   @relation(fields: [orgId, cartId], references: [orgId, id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("orders")
}

enum OrderStatus {
  pending
  failed
  refunded
  partial_refund
  completed
  expired
  cancelled
  fraudulent
}

model OrderItem {
  orgId String @map("org_id")
  id    String @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id], onDelete: Cascade)

  productId String @map("product_id")
  priceId   String @map("price_id")

  description String
  quantity    Int

  subTotal      Int @default(0) @map("sub_total")
  total         Int @default(0)
  taxTotal      Int @default(0) @map("tax_total")
  discountTotal Int @default(0) @map("discount_total")

  metadata Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Variant Variant? @relation(fields: [orgId, variantId], references: [orgId, id])

  variantId String? @map("variant_id")

  // The subscription that bills this recurring line (null for one-time lines).
  // A subscription owns the order's recurring lines that share one cadence.
  subscriptionId String?       @map("subscription_id")
  subscription   Subscription? @relation("SubscriptionLines", fields: [orgId, subscriptionId], references: [orgId, id])

  @@id([orgId, id])
  @@map("order_items")
}

model Customer {
  orgId String @map("org_id")
  id    String @default(cuid())

  externalId     String? @map("external_id")
  email          String
  firstName      String? @map("first_name")
  lastName       String? @map("last_name")
  phone          String?
  billingAddress Json?   @map("billing_address")

  metadata               Json?
  defaultPaymentMethodId String?        @map("default_payment_method_id")
  defaultPaymentMethod   PaymentMethod? @relation(name: "dpm", fields: [orgId, defaultPaymentMethodId], references: [orgId, id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders         Order[]
  paymentMethods PaymentMethod[]  @relation(name: "pmc")
  subscriptions  Subscription[]
  cohorts        CustomerCohort[]
  org            Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id], map: "customer_primary_key")
  @@unique([orgId, email])
  @@unique([orgId, externalId])
  @@index([orgId, email])
  @@map("customers")
}

model Cohort {
  orgId     String           @map("org_id")
  id        String           @default(cuid())
  name      String
  type      String           @default("signup")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  customers CustomerCohort[]

  @@id([orgId, id], map: "cohort_primary_key")
  @@map("cohorts")
}

model CustomerCohort {
  orgId       String   @map("org_id")
  customerId  String   @map("customer_id")
  cohortId    String   @map("cohort_id")
  cohortValue String   @map("cohort_value")
  joinedAt    DateTime @default(now()) @map("joined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)
  cohort   Cohort   @relation(fields: [orgId, cohortId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, customerId, cohortId])
  @@map("customer_cohorts")
}

model PaymentMethod {
  orgId String @map("org_id")
  id    String @default(cuid())

  status     PaymentMethodStatus @default(active)
  psp        String
  name       String?
  customerId String              @map("customer_id")
  customer   Customer            @relation(name: "pmc", fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)

  billingAddress Json?          @map("billing_address")
  details        Json?
  type           String
  token          String
  metadata       Json?
  expireAt       DateTime?      @map("expire_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  subscriptions  Subscription[]
  Customer       Customer[]     @relation(name: "dpm")

  @@id([orgId, id], map: "paymentmethod_pk")
  @@map("payment_methods")
}

enum PaymentMethodStatus {
  active
  expired
}

model Subscription {
  orgId String @map("org_id")
  id    String @default(cuid())

  pspId String @map("psp_id")

  status SubscriptionStatus

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  // A subscription bills a group of the order's recurring lines (one cadence).
  lines OrderItem[] @relation("SubscriptionLines")

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [orgId, customerId], references: [orgId, id])

  paymentMethodId String?        @map("payment_method_id")
  paymentMethod   PaymentMethod? @relation(fields: [orgId, paymentMethodId], references: [orgId, id])

  startDate          DateTime?       @map("start_date")
  endDate            DateTime?       @map("end_date")
  billingInterval    BillingInterval @map("billing_interval")
  billingIntervalQty Int             @map("billing_interval_qty")
  cycles             Int
  billingAnchor      Int             @map("billing_anchor")
  // Trial cadence the subscription derived from its lines at construction (so
  // activation needs no Price lookup).
  trialInterval      BillingInterval @default(none) @map("trial_interval")
  trialIntervalQty   Int             @default(0) @map("trial_interval_qty")
  trialEndsAt        DateTime?       @map("trial_ends_at")
  cancelAt           DateTime?       @map("cancel_at")
  endsAt             DateTime?       @map("ends_at")
  lastCharge         DateTime?       @map("last_charge")
  renewsAt           DateTime?       @map("renews_at")
  currentPeriodStart DateTime?       @map("current_period_start")
  currentPeriodEnd   DateTime?       @map("current_period_end")

  retries   Int?
  nextRetry DateTime? @map("next_retry")

  currency String

  metadata Json

  cyclesProcessed Int       @map("cycles_processed")
  totalRevenue    Int       @map("total_revenue")
  cancelledAt     DateTime? @map("cancelled_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  payments  Payment[]

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  trial
  active
  retry
  past_due
  paused
  unpaid
  cancelled
  pending
  expired
  completed
}

model Payment {
  orgId String @map("org_id")
  id    String @default(cuid())

  psp       String  @map("psp")
  pspId     String? @map("psp_id")
  reference String  @default("") @map("reference")
  recurring Boolean @default(false)

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  subscriptionId String?       @map("subscription_id")
  subscription   Subscription? @relation(fields: [orgId, subscriptionId], references: [orgId, id])

  invoiceId String? @map("invoice_id")

  amount   Int
  currency String

  status PaymentStatus

  psp_fee      Int
  platform_fee Int
  net_amount   Int

  refunded_amount Int @default(0) @map("refunded_amount")

  metadata Json?

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org     Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@id([orgId, id])
  @@map("payments")
}

enum PaymentStatus {
  pending
  failed
  succeeded
  refunded
  partial_refund
  cancelled
  expired
  fraudulent
}

model Refund {
  orgId         String   @map("org_id")
  id            String   @default(cuid())
  psp_refund_id String?  @map("psp_refund_id")
  paymentId     String   @map("payment_id")
  payment       Payment  @relation(fields: [orgId, paymentId], references: [orgId, id], onDelete: Cascade)
  amount        Int
  currency      String
  reason        String?
  refunded_at   DateTime @map("refunded_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@map("refunds")
}

model IdempotencyKey {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id, expiresAt])
  @@map("idempotency_keys")
}

model WebhookSubscription {
  orgId     String   @map("org_id")
  id        String   @id @default(cuid())
  events    String[]
  url       String
  secret    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("webhook_subscriptions")
}

model MetadataStore {
  orgId      String   @map("org_id")
  parentId   String   @map("parent_id")
  parentType String?  @map("parent_type")
  key        String
  value      String
  namespace  String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, parentId, key])
  @@index([orgId, key, value], name: "metadata_store_org_id_key_value_idx")
  @@index([orgId, parentId], name: "metadata_store_org_id_parent_id_idx")
  @@index([orgId, parentType, key], name: "metadata_store_org_id_parent_type_key_idx")
  @@index([parentId], name: "metadata_store_parent_id_idx")
  @@map("metadata_store")
}

// ============================================================================
// Dunning
//
// One DunningCampaign per failed subscription charge, owning attempts and
// communications. Configurations are org-scoped policy bundles; tokens are
// magic-links delivered to customers to update payment details.
// ============================================================================

enum DunningStatus {
  active
  paused
  recovered
  failed
  cancelled
  expired
}

enum DunningAttemptType {
  immediate
  progressive
  manual
  triggered
}

enum CommunicationChannel {
  email
  sms
  push
  webhook
  in_app
}

enum CommunicationStatus {
  pending
  sent
  delivered
  failed
  bounced
}

enum TokenStatus {
  active
  expired
  revoked
  max_uses_reached
}

enum DunningConfigScope {
  organization
  customer_segment
  subscription_tier
  customer
  ab_test
}

enum DunningConfigStatus {
  active
  inactive
  archived
}

model DunningCampaign {
  orgId String @map("org_id")
  id    String

  subscriptionId String @map("subscription_id")
  customerId     String @map("customer_id")

  workflowId       String  @default("") @map("workflow_id")
  workflowRunId    String  @default("") @map("workflow_run_id")
  parentWorkflowId String? @map("parent_workflow_id")

  status               DunningStatus
  failedAmount         BigInt        @map("failed_amount")
  currency             String
  initialFailureReason String?       @map("initial_failure_reason")

  totalAttempts       Int @default(0) @map("total_attempts")
  immediateAttempts   Int @default(0) @map("immediate_attempts")
  progressiveAttempts Int @default(0) @map("progressive_attempts")

  startedAt     DateTime  @map("started_at")
  lastAttemptAt DateTime? @map("last_attempt_at")
  nextAttemptAt DateTime? @map("next_attempt_at")
  completedAt   DateTime? @map("completed_at")

  recoveryMethod     String?   @map("recovery_method")
  recoveredAmount    BigInt?   @map("recovered_amount")
  recoveredAt        DateTime? @map("recovered_at")
  finalFailureReason String?   @map("final_failure_reason")

  configSnapshot Json? @map("config_snapshot")
  metadata       Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attempts       DunningAttempt[]
  communications DunningCommunication[]

  @@id([orgId, id])
  @@index([orgId, subscriptionId], name: "dunning_campaigns_org_id_subscription_id_idx")
  @@index([orgId, customerId], name: "dunning_campaigns_org_id_customer_id_idx")
  @@index([orgId, status], name: "dunning_campaigns_org_id_status_idx")
  @@map("dunning_campaigns")
}

model DunningAttempt {
  orgId String @map("org_id")
  id    String

  dunningCampaignId String @map("dunning_campaign_id")
  subscriptionId    String @map("subscription_id")

  attemptNumber Int                @map("attempt_number")
  attemptType   DunningAttemptType @map("attempt_type")

  amount          BigInt
  currency        String
  paymentMethodId String? @map("payment_method_id")

  status            String
  failureReason     String? @map("failure_reason")
  failureCode       String? @map("failure_code")
  processorResponse Json?   @map("processor_response")

  processingTimeMs Int?      @map("processing_time_ms")
  attemptedAt      DateTime  @map("attempted_at")
  completedAt      DateTime? @map("completed_at")

  triggeredBy String? @map("triggered_by")
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  campaign DunningCampaign @relation(fields: [orgId, dunningCampaignId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, id])
  @@index([orgId, dunningCampaignId], name: "dunning_attempts_org_id_campaign_id_idx")
  @@map("dunning_attempts")
}

model DunningCommunication {
  orgId String @map("org_id")
  id    String

  dunningCampaignId String @map("dunning_campaign_id")
  customerId        String @map("customer_id")

  channel       CommunicationChannel
  templateId    String               @map("template_id")
  attemptNumber Int                  @map("attempt_number")

  subject             String?
  contentPreview      String? @map("content_preview")
  personalizationData Json?   @map("personalization_data")

  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  openedAt    DateTime? @map("opened_at")
  clickedAt   DateTime? @map("clicked_at")
  bouncedAt   DateTime? @map("bounced_at")

  provider          String
  providerMessageId String? @map("provider_message_id")
  providerResponse  Json?   @map("provider_response")

  status        CommunicationStatus
  failureReason String?             @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign DunningCampaign @relation(fields: [orgId, dunningCampaignId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, id])
  @@index([orgId, dunningCampaignId], name: "dunning_comms_org_id_campaign_id_idx")
  @@map("dunning_communications")
}

model PaymentUpdateToken {
  orgId   String @map("org_id")
  tokenId String @map("token_id")

  subscriptionId    String  @map("subscription_id")
  customerId        String  @map("customer_id")
  dunningCampaignId String? @map("dunning_campaign_id")

  tokenData Json?  @map("token_data")
  signature String

  expiresAt DateTime @map("expires_at")
  maxUses   Int      @default(5) @map("max_uses")
  usedCount Int      @default(0) @map("used_count")

  status         TokenStatus
  allowedActions Json?       @map("allowed_actions")

  adminGenerated Boolean @default(false) @map("admin_generated")
  adminUserId    String? @map("admin_user_id")
  adminReason    String? @map("admin_reason")
  adminNotes     String? @map("admin_notes")

  createdBy  String?   @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  lastUsedIp String?   @map("last_used_ip")

  @@id([orgId, tokenId])
  @@index([orgId, subscriptionId], name: "payment_update_tokens_org_id_subscription_id_idx")
  @@index([orgId, dunningCampaignId], name: "payment_update_tokens_org_id_campaign_id_idx")
  @@map("payment_update_tokens")
}

model DunningConfiguration {
  orgId String @map("org_id")
  id    String

  name        String
  description String?
  priority    Int     @default(0)

  appliesTo   DunningConfigScope @map("applies_to")
  targetRules Json?              @map("target_rules")
  config      Json

  status           DunningConfigStatus
  isAbTest         Boolean             @default(false) @map("is_ab_test")
  abTestPercentage Float?              @map("ab_test_percentage")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@index([orgId, status, priority], name: "dunning_configurations_org_id_status_priority_idx")
  @@map("dunning_configurations")
}

model CustomerDunningHistory {
  orgId      String @map("org_id")
  customerId String @map("customer_id")

  totalDunningCampaigns Int @default(0) @map("total_dunning_campaigns")
  successfulRecoveries  Int @default(0) @map("successful_recoveries")
  failedCampaigns       Int @default(0) @map("failed_campaigns")

  totalAmountAtRisk    BigInt @default(0) @map("total_amount_at_risk")
  totalAmountRecovered BigInt @default(0) @map("total_amount_recovered")
  totalAmountLost      BigInt @default(0) @map("total_amount_lost")

  avgRecoveryTimeHours    Float?                @map("avg_recovery_time_hours")
  preferredRecoveryMethod String?               @map("preferred_recovery_method")
  mostResponsiveChannel   CommunicationChannel? @map("most_responsive_channel")
  paymentReliabilityScore Float?                @map("payment_reliability_score")
  dunningRiskTier         String?               @map("dunning_risk_tier")

  firstDunningAt DateTime? @map("first_dunning_at")
  lastDunningAt  DateTime? @map("last_dunning_at")
  lastRecoveryAt DateTime? @map("last_recovery_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([orgId, customerId])
  @@map("customer_dunning_history")
}

model BillableMetric {
  orgId String @map("org_id")
  id    String @default(cuid())

  code          String
  name          String
  aggregation   String
  fieldName     String? @map("field_name")
  carryOver     Boolean @default(false) @map("carry_over")
  roundingMode  String? @map("rounding_mode")
  roundingScale Int     @default(0) @map("rounding_scale")
  // filters: rate dimensions [{field,values}] — each value gets its own Price.
  // groupBy: open breakout dimensions (key names) — usage split into one invoice line
  // per discovered value at the Price's single rate. usage-filters-and-groups.md.
  filters       Json?
  groupBy       Json?   @map("group_by")
  metadata      Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@unique([orgId, code])
  @@map("billable_metrics")
}

