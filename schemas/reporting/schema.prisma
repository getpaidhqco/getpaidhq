generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("REPORTING_DATABASE_URL")
}

enum PriceCategory {
  one_time
  subscription
  free
  variable
}

enum PriceScheme {
  fixed
  tiered
  volume
  graduated
}

enum BillingInterval {
  none
  minute
  hour
  day
  week
  month
  year
}

enum SubscriptionStatus {
  trial
  active
  retry
  past_due
  paused
  unpaid
  cancelled
  pending
  expired
  completed
}

enum PaymentStatus {
  pending
  failed
  succeeded
  refunded
  partial_refund
  cancelled
  expired
  fraudulent
}

model DailyMetric {
  orgId       String   @map("org_id")
  date        DateTime
  timezone    String   @map("timezone")
  dayStartUtc DateTime @map("day_start_utc")
  dayEndUtc   DateTime @map("day_end_utc")

  currency     String
  arr          Int    @default(0) @map("arr")
  mrr          Int    @default(0) @map("mrr")
  pastDueTotal Int    @default(0) @map("past_due_total")
  pastDueCount Int    @default(0) @map("past_due_count")

  customersAtStart Int   @default(0) @map("customers_at_start")
  customerCount    Int   @default(0) @map("customer_count")
  churnCount       Int   @default(0) @map("churn_count")
  churnTotal       Int   @default(0) @map("churn_total")
  churnRate        Float @default(0.0) @map("churn_rate")

  aveRevenuePerUser     Float    @default(0.0) @map("ave_revenue_per_user")
  customerLifetimeValue Int      @default(0) @map("customer_lifetime_value")
  successfulPayments    Int      @default(0) @map("successful_payments")
  failedPayments        Int      @default(0) @map("failed_payments")
  refundCount           Int      @default(0) @map("refund_count")
  refundTotal           Int      @default(0) @map("refund_total")
  createdAt             DateTime @default(now()) @map("created_at")

  @@id([orgId, date])
  @@map("daily_metrics")
}

model Subscription {
  orgId             String             @map("org_id")
  id                String             @default(cuid())
  pspId             String             @map("psp_id")
  status            SubscriptionStatus
  orderId           String             @map("order_id")
  orderItemId       String?            @map("order_item_id")
  orderItemName     String?            @map("order_item_name")
  customerId        String             @map("customer_id")
  paymentMethodId   String?            @map("payment_method_id")
  paymentMethodType String?            @map("payment_method_type")

  startDate          DateTime?       @map("start_date")
  endDate            DateTime?       @map("end_date")
  billingInterval    BillingInterval @map("billing_interval")
  billingIntervalQty Int             @map("billing_interval_qty")
  cycles             Int
  billingAnchor      Int             @map("billing_anchor")
  trialEndsAt        DateTime?       @map("trial_ends_at")
  cancelAt           DateTime?       @map("cancel_at")
  endsAt             DateTime?       @map("ends_at")
  lastCharge         DateTime?       @map("last_charge")
  renewsAt           DateTime?       @map("renews_at")
  currentPeriodStart DateTime?       @map("current_period_start")
  currentPeriodEnd   DateTime?       @map("current_period_end")

  retries   Int?
  nextRetry DateTime? @map("next_retry")

  currency String
  amount   Int

  cyclesProcessed Int       @map("cycles_processed")
  totalRevenue    Int       @map("total_revenue")
  cancelledAt     DateTime? @map("cancelled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@map("subscriptions")
}

model Payment {
  orgId String @map("org_id")
  id    String @default(cuid())

  psp       String  @map("psp")
  pspId     String? @map("psp_id")
  reference String  @default("") @map("reference")
  recurring Boolean @default(false)

  orderId        String  @map("order_id")
  subscriptionId String? @map("subscription_id")

  amount   Int
  currency String

  status PaymentStatus

  psp_fee      Int
  platform_fee Int
  net_amount   Int

  metadata Json?

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@map("payments")
}

model Customers {
  orgId     String   @map("org_id")
  id        String   @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@map("customers")
}

model CustomerCohort {
  orgId       String   @map("org_id")
  customerId  String   @map("customer_id")
  cohortId    String   @map("cohort_id")
  cohortValue String   @map("cohort_value")
  joinedAt    DateTime @default(now()) @map("joined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([orgId, customerId, cohortId])
  @@map("customer_cohorts")
}

model Refund {
  orgId         String   @map("org_id")
  id            String   @default(cuid())
  psp_refund_id String?  @map("psp_refund_id")
  paymentId     String   @map("payment_id")
  currency      String
  amount        Int
  refundedAt    DateTime @map("refunded_at")
  reason        String?
  usd_amount    Int?     @map("usd_amount")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@map("refunds")
}
