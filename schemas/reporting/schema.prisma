generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("REPORTING_DATABASE_URL")
}

model DailyMetrics {
  date               DateTime @id
  currency           String
  arr                Int
  mrr                Int
  customerCount      Int      @map("customer_count")
  churnRate          Float    @map("churn_rate")
  arpu               Float
  cltv               Float
  successfulPayments Int      @map("successful_payments")
  failedPayments     Int      @map("failed_payments")
  refunds            Float
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("daily_metrics")
}
