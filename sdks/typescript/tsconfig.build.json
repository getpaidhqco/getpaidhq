{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist"
  },
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "tests",
    "examples",
    "scripts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}