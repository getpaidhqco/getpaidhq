// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("GPHQ_DATABASE_URL")
}

enum OrgStatus {
  active
  trial
  demo
  inactive
  deleted
}

enum InvoiceStatus {
  draft // Mutable, can be modified
  sent // Immutable, delivered to customer
  paid // Payment received
  overdue // Past due date
  cancelled // Cancelled before payment
  refunded // Fully refunded via credit notes
}

enum CreditNoteReason {
  correction // Pricing/calculation error
  cancellation // Order cancelled
  refund // Product/service return
  adjustment // Discount applied
  tax_adjustment // Tax correction
}

enum InvoiceType {
  initial // First purchase invoice (links to order)
  recurring // Regular subscription billing (links to subscription)
  usage // Usage-based charges over plan limits
  adjustment // Proration, credits, billing corrections
  setup // One-time setup/implementation fees
  cancellation // Early termination or final charges
  refund // Refund processing invoices
}

enum InvoiceHistoryAction {
  created // Invoice initially created
  updated // Invoice details modified (draft only)
  sent // Invoice sent to customer
  viewed // Customer viewed invoice
  paid // Payment received
  partial_paid // Partial payment received
  overdue // Invoice became overdue
  reminded // Payment reminder sent
  voided // Invoice cancelled/voided
  credited // Credit note applied
  refunded // Payment refunded
  disputed // Customer disputed invoice
  adjusted // Manual adjustment made
}

enum DocumentType {
  invoice // Standard invoice for payment
  proforma // Proforma invoice (quote/estimate)
  quote // Formal quote/proposal
  receipt // Payment receipt
  statement // Account statement
}

model ApiKey {
  orgId     String   @map("org_id")
  id        String   @default(cuid())
  key       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("api_keys")
}

model Org {
  id                   String                 @id
  country              String
  status               OrgStatus              @default(active)
  name                 String
  timezone             String                 @default("UTC")
  metadata             Json?
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  users                UserOrg[]
  Session              Session[]
  Variant              Variant[]
  Price                Price[]
  Order                Order[]
  Customer             Customer[]
  Subscription         Subscription[]
  Payment              Payment[]
  Setting              Setting[]
  OrderItem            OrderItem[]
  ApiKey               ApiKey[]
  MetadataStore        MetadataStore[]
  DunningCampaign      DunningCampaign[]
  DunningConfiguration DunningConfiguration[]
  SubscriptionItem     SubscriptionItem[]
  PriceTier            PriceTier[]
  Meter                Meter[]

  @@map("orgs")
}

model Gateway {
  orgId  String  @map("org_id")
  id     String
  name   String
  pspId  String  @map("psp_id")
  active Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@id([orgId, id])
  @@map("gateways")
}

model Setting {
  orgId     String @map("org_id")
  parentId  String @map("parent_id")
  id        String
  valueType String @map("value_type")
  value     Json

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, parentId, id])
  @@map("settings")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  UserOrg   UserOrg[]

  @@map("users")
}

model UserOrg {
  userId String @map("user_id")
  orgId  String @map("org_id")

  user User @relation(fields: [userId], references: [id])
  org  Org  @relation(fields: [orgId], references: [id])

  role Role @default(user)

  @@id([userId, orgId])
  @@map("user_orgs")
}

enum Role {
  owner
  admin
  user
}

model Cart {
  orgId String @map("org_id")
  id    String @default(cuid())

  data     Json?
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  order     Order[]

  @@id([orgId, id])
  @@map("carts")
}

model Product {
  orgId String @map("org_id")
  id    String @default(cuid())

  name        String
  description String?

  metadata Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  Variant   Variant[]

  @@id([orgId, id])
  @@map("products")
}

model Variant {
  orgId String @map("org_id")
  id    String @default(cuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [orgId, productId], references: [orgId, id], onDelete: Cascade)

  name        String
  description String?

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  Price     Price[]

  org       Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  OrderItem OrderItem[]

  @@id([orgId, id])
  @@map("variants")
}

// Meter defines how to measure usage
model Meter {
  orgId       String  @map("org_id")
  id          String
  slug        String
  name        String
  description String?

  // Event configuration
  eventName   String @map("event_name")
  eventFilter Json?  @map("event_filter")

  // Aggregation configuration
  aggregationType String  @map("aggregation_type")
  valueProperty   String? @map("value_property")

  // Display configuration
  unitType    String @map("unit_type")
  displayName String @map("display_name")

  // Window configuration
  windowSize    String? @map("window_size")
  resetInterval String? @map("reset_interval")

  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  Org              Org                @relation(fields: [orgId], references: [id])
  Price            Price[]
  SubscriptionItem SubscriptionItem[]

  @@id([orgId, id])
  @@unique([orgId, slug])
  @@index([orgId, eventName])
  @@map("meters")
}

model Price {
  orgId String @map("org_id")
  id    String @default(cuid())

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [orgId, variantId], references: [orgId, id], onDelete: Cascade)

  category PriceCategory
  scheme   PriceScheme

  label String?

  currency  String
  unitPrice Int    @map("unit_price")

  cycles             Int?
  billingInterval    BillingInterval? @map("billing_interval")
  billingIntervalQty Int?             @map("billing_interval_qty")

  trialInterval    BillingInterval? @map("trial_interval")
  trialIntervalQty Int?             @map("trial_interval_qty")

  minPrice       Int? @map("min_price")
  suggestedPrice Int? @map("suggested_price")

  taxCode String? @map("tax_code")

  // Meter reference (NEW)
  meterId String? @map("meter_id")
  Meter   Meter?  @relation(fields: [orgId, meterId], references: [orgId, id])

  // Usage Configuration (Required for usage-based billing)
  hasUsage        Boolean @default(false) @map("has_usage")
  usageType       String? @map("usage_type") // "metered"
  unitType        String? @map("unit_type") // "count", "transactions", "gb_hours", etc.
  aggregationType String? @map("aggregation_type") // "sum", "max", "average", "last_during_period"

  // Pricing Models (Required for transaction fees & hybrid models)
  percentageRate   Float? @map("percentage_rate") // 2.9% for payment processing
  fixedFee         Int?   @map("fixed_fee") // $0.30 per transaction
  overageUnitPrice Int?   @map("overage_unit_price") // For hybrid models with overage pricing

  // Optional: Future features
  includedUsage Int? @map("included_usage") // Free tier allowance
  usageLimit    Int? @map("usage_limit") // Hard limits

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org              Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  SubscriptionItem SubscriptionItem[]
  tiers            PriceTier[]

  @@id([orgId, id])
  @@map("prices")
}

model PriceTier {
  orgId       String  @map("org_id")
  priceId     String  @map("price_id")
  tier        Int // Tier order (1, 2, 3...)
  fromQty     Int     @map("from_qty") // Starting quantity (inclusive)
  toQty       Int?    @map("to_qty") // Ending quantity (inclusive, null = unlimited)
  unitPrice   Int     @map("unit_price") // Price per unit in cents
  description String? // Human readable description

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  price Price @relation(fields: [orgId, priceId], references: [orgId, id], onDelete: Cascade)
  org   Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, priceId, tier])
  @@index([orgId, priceId])
  @@map("price_tiers")
}

enum PriceCategory {
  one_time
  subscription
  usage
  hybrid
  free
  variable
}

enum PriceScheme {
  fixed
  tiered
  volume
  graduated
}

enum BillingInterval {
  none
  minute
  hour
  day
  week
  month
  year
}

model Session {
  orgId String @map("org_id")
  id    String @default(cuid())

  cartId String? @map("cart_id")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("sessions")
}

model Order {
  orgId      String      @map("org_id")
  id         String      @default(cuid())
  customerId String      @map("customer_id")
  customer   Customer    @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Restrict)
  status     OrderStatus

  reference String

  sessionId String @map("session_id")

  currency String
  total    Int

  metadata Json

  items         OrderItem[]
  subscriptions Subscription[]
  payments      Payment[]

  cartId String @map("cart_id")
  cart   Cart   @relation(fields: [orgId, cartId], references: [orgId, id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Invoice Invoice[]

  @@id([orgId, id])
  @@map("orders")
}

enum OrderStatus {
  pending
  failed
  refunded
  partial_refund
  completed
  expired
  cancelled
  fraudulent
}

model OrderItem {
  orgId String @map("org_id")
  id    String @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id], onDelete: Cascade)

  productId String @map("product_id")
  priceId   String @map("price_id")

  description String
  quantity    Decimal @db.Decimal(10, 3)

  subTotal      Int @default(0) @map("sub_total")
  total         Int @default(0)
  taxTotal      Int @default(0) @map("tax_total")
  discountTotal Int @default(0) @map("discount_total")

  metadata Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Variant Variant? @relation(fields: [orgId, variantId], references: [orgId, id])

  variantId    String?        @map("variant_id")
  Subscription Subscription[]

  @@id([orgId, id])
  @@map("order_items")
}

model Customer {
  orgId String @map("org_id")
  id    String @default(cuid())

  email          String
  firstName      String? @map("first_name")
  lastName       String? @map("last_name")
  phone          String?
  billingAddress Json?   @map("billing_address")

  metadata               Json?
  defaultPaymentMethodId String?        @map("default_payment_method_id")
  defaultPaymentMethod   PaymentMethod? @relation(name: "dpm", fields: [orgId, defaultPaymentMethodId], references: [orgId, id])

  // Dunning preferences
  dunningPreferences Json? @map("dunning_preferences")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders         Order[]
  paymentMethods PaymentMethod[]  @relation(name: "pmc")
  subscriptions  Subscription[]
  cohorts        CustomerCohort[]
  org            Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Invoice        Invoice[]

  // Dunning relationships
  dunningCampaigns      DunningCampaign[]
  dunningCommunications DunningCommunication[]
  paymentTokens         PaymentUpdateToken[]
  dunningHistory        CustomerDunningHistory?

  @@id([orgId, id], map: "customer_primary_key")
  @@unique([orgId, email])
  @@index([orgId, email])
  @@map("customers")
}

model Cohort {
  orgId     String           @map("org_id")
  id        String           @default(cuid())
  name      String           @map("name")
  type      String           @default("signup") @map("type")
  metadata  Json?            @map("metadata")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  customers CustomerCohort[]

  @@id([orgId, id], map: "cohort_primary_key")
  @@map("cohorts")
}

model CustomerCohort {
  orgId       String   @map("org_id")
  customerId  String   @map("customer_id")
  cohortId    String   @map("cohort_id")
  cohortValue String   @map("cohort_value")
  joinedAt    DateTime @default(now()) @map("joined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)
  cohort   Cohort   @relation(fields: [orgId, cohortId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, customerId, cohortId])
  @@map("customer_cohorts")
}

model PaymentMethod {
  orgId String @map("org_id")
  id    String @default(cuid())

  status     PaymentMethodStatus @default(active)
  psp        String              @map("psp")
  name       String?             @map("name")
  customerId String              @map("customer_id")
  customer   Customer            @relation(name: "pmc", fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)

  billingAddress Json?          @map("billing_address")
  details        Json?          @map("details")
  type           String         @map("type")
  token          String         @map("token")
  metadata       Json?          @map("metadata")
  expireAt       DateTime?      @map("expire_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  subscriptions  Subscription[]
  Customer       Customer[]     @relation(name: "dpm")

  @@id([orgId, id], map: "paymentmethod_pk")
  @@map("payment_methods")
}

enum PaymentMethodStatus {
  active
  expired
}

model Subscription {
  orgId String @map("org_id")
  id    String @default(cuid())

  pspId String @map("psp_id")

  status SubscriptionStatus

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  orderItemId String    @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orgId, orderItemId], references: [orgId, id])

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [orgId, customerId], references: [orgId, id])

  paymentMethodId String?        @map("payment_method_id")
  paymentMethod   PaymentMethod? @relation(fields: [orgId, paymentMethodId], references: [orgId, id])

  // Optional amount and currency for backward compatibility
  amount   Int? // Optional for multi-item subscriptions
  currency String? // Optional for multi-item subscriptions

  startDate          DateTime?       @map("start_date")
  endDate            DateTime?       @map("end_date")
  billingInterval    BillingInterval @map("billing_interval")
  billingIntervalQty Int             @map("billing_interval_qty")
  cycles             Int
  billingAnchor      Int             @map("billing_anchor")
  trialEndsAt        DateTime?       @map("trial_ends_at")
  cancelAt           DateTime?       @map("cancel_at")
  endsAt             DateTime?       @map("ends_at")
  lastCharge         DateTime?       @map("last_charge")
  renewsAt           DateTime?       @map("renews_at")
  currentPeriodStart DateTime?       @map("current_period_start")
  currentPeriodEnd   DateTime?       @map("current_period_end")

  metadata Json

  cyclesProcessed Int       @map("cycles_processed")
  totalRevenue    Int       @map("total_revenue")
  cancelledAt     DateTime? @map("cancelled_at")

  // Dunning-related additions
  dunningActive           Boolean @default(false) @map("dunning_active")
  activeDunningCampaignId String? @map("active_dunning_campaign_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  payments  Payment[]

  org     Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Invoice Invoice[]

  // Dunning relationships
  dunningCampaigns DunningCampaign[]
  paymentTokens    PaymentUpdateToken[]

  // Relation to subscription plan changes
  planChanges SubscriptionPlanChange[]

  // Relation to subscription items
  items SubscriptionItem[]

  @@id([orgId, id])
  @@map("subscriptions")
}

model SubscriptionItem {
  orgId          String @map("org_id")
  id             String @default(cuid())
  subscriptionId String @map("subscription_id")

  // Product/Price reference
  priceId   String  @map("price_id")
  productId String? @map("product_id")
  variantId String? @map("variant_id")

  // Meter reference (NEW)
  meterId String? @map("meter_id")
  Meter   Meter?  @relation(fields: [orgId, meterId], references: [orgId, id])

  // Item details
  name        String
  description String?
  status      SubscriptionItemStatus @default(active)

  // Quantity for fixed items
  quantity Int @default(1)

  // Billing
  amount   Int? // Fixed amount per period (null for pure usage)
  currency String

  // Pricing configuration (COPIED from Price at creation time for grandfathering)
  percentageRate   Float? @map("percentage_rate") // For percentage-based charges
  fixedFee         Int?   @map("fixed_fee") // Fixed fee per unit
  unitPrice        Int?   @map("unit_price") // Price per unit
  overageUnitPrice Int?   @map("overage_unit_price") // For hybrid models with overage pricing
  includedUsage    Int?   @map("included_usage") // Free tier allowance
  usageLimit       Int?   @map("usage_limit") // Hard limits

  // Price snapshot for comparison/audit (NEW)
  priceSnapshot Json? @map("price_snapshot")

  // Usage configuration
  hasUsage        Boolean @default(false) @map("has_usage")
  usageType       String? @map("usage_type") // "metered", "licensed"
  aggregationType String? @map("aggregation_type") // "sum", "max", "last_during_period"

  // Metadata
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  subscription Subscription @relation(fields: [orgId, subscriptionId], references: [orgId, id])
  price        Price        @relation(fields: [orgId, priceId], references: [orgId, id])
  org          Org          @relation(fields: [orgId], references: [id])

  @@id([orgId, id])
  @@index([orgId, subscriptionId])
  @@index([orgId, subscriptionId, status])
  @@map("subscription_items")
}

enum SubscriptionItemStatus {
  active
  paused
  cancelled
  pending
}

model SubscriptionPlanChange {
  id             String @default(cuid())
  orgId          String @map("org_id")
  subscriptionId String @map("subscription_id")

  fromProductId String @map("from_product_id")
  fromVariantId String @map("from_variant_id")
  fromPriceId   String @map("from_price_id")
  fromAmount    BigInt @map("from_amount")

  toProductId String @map("to_product_id")
  toVariantId String @map("to_variant_id")
  toPriceId   String @map("to_price_id")
  toAmount    BigInt @map("to_amount")

  changeType      String   @map("change_type")
  effectiveDate   DateTime @map("effective_date")
  prorationMode   String   @map("proration_mode")
  prorationAmount BigInt   @map("proration_amount")
  reason          String?  @map("reason")
  initiatedBy     String   @map("initiated_by")
  metadata        Json?    @map("metadata")
  createdAt       DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [orgId, subscriptionId], references: [orgId, id])

  @@id([orgId, id])
  @@map("subscription_plan_changes")
}

enum SubscriptionStatus {
  trial
  active
  retry
  past_due
  paused
  unpaid
  cancelled
  pending
  expired
  completed
  non_renewing
}

model Payment {
  orgId String @map("org_id")
  id    String @default(cuid())

  psp       String  @map("psp")
  pspId     String? @map("psp_id")
  reference String  @default("") @map("reference")
  recurring Boolean @default(false)

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  invoiceId String?  @map("invoice_id")
  Invoice   Invoice? @relation(fields: [orgId, invoiceId], references: [orgId, id])

  subscriptionId String?       @map("subscription_id")
  subscription   Subscription? @relation(fields: [orgId, subscriptionId], references: [orgId, id])

  // Dunning context
  dunningCampaignId    String? @map("dunning_campaign_id")
  dunningAttemptNumber Int?    @map("dunning_attempt_number")
  isDunningRecovery    Boolean @default(false) @map("is_dunning_recovery")

  amount   Int
  currency String

  status PaymentStatus

  pspFee      Int @map("psp_fee")
  platformFee Int @map("platform_fee")
  netAmount   Int @map("net_amount")

  refundedAmount Int @default(0) @map("refunded_amount")

  metadata Json?

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org     Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@id([orgId, id])
  @@index([orgId, invoiceId])
  @@index([orgId, subscriptionId])
  @@map("payments")
}

enum PaymentStatus {
  pending
  failed
  succeeded
  refunded
  partial_refund
  cancelled
  expired
  fraudulent
}

enum RefundStatus {
  pending
  completed
  error
}

model Refund {
  orgId         String       @map("org_id")
  id            String       @default(cuid())
  psp_refund_id String?      @map("psp_refund_id")
  paymentId     String       @map("payment_id")
  payment       Payment      @relation(fields: [orgId, paymentId], references: [orgId, id], onDelete: Cascade)
  amount        Int
  currency      String
  reason        String?
  status        RefundStatus @default(pending)
  refunded_at   DateTime     @map("refunded_at")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@map("refunds")
}

model IdempotencyKey {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id, expiresAt])
  @@map("idempotency_keys")
}

model WebhookSubscription {
  orgId     String   @map("org_id")
  id        String   @id @default(cuid())
  events    String[]
  url       String
  secret    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("webhook_subscriptions")
}

model MetadataStore {
  orgId      String   @map("org_id")
  parentId   String   @map("parent_id")
  parentType String?  @map("parent_type")
  key        String
  value      String
  namespace  String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, parentId, key])
  @@index([orgId, key, value], name: "metadata_store_org_id_key_value_idx")
  @@index([orgId, parentId], name: "metadata_store_org_id_parent_id_idx")
  @@index([orgId, parentType, key], name: "metadata_store_org_id_parent_type_key_idx")
  @@index([parentId], name: "metadata_store_parent_id_idx")
  @@map("metadata_store")
}

model Invoice {
  orgId String @map("org_id")
  id    String @default(cuid())

  // References - hybrid approach
  customerId     String? @map("customer_id")
  orderId        String? @map("order_id") // For initial purchase invoices
  subscriptionId String? @map("subscription_id") // For recurring invoices

  // Document identity
  sequenceId  String       @map("sequence_id") // From doc sequence
  docNumber   String       @map("doc_number") // Human readable: INV-001
  type        DocumentType @default(invoice) // "invoice", "proforma", "quote"
  invoiceType InvoiceType  @map("invoice_type") // Why this invoice exists

  // Status and immutability
  status      InvoiceStatus @default(draft)
  isImmutable Boolean       @default(false) @map("is_immutable")

  // Financial data
  currency      String @default("USD")
  subTotal      Int    @map("sub_total")
  taxTotal      Int    @map("tax_total")
  discountTotal Int    @default(0) @map("discount_total")
  total         Int
  amountPaid    Int    @default(0) @map("amount_paid")
  amountDue     Int    @map("amount_due")

  // Tax integration
  taxProvider      String? @map("tax_provider") // "avalara", "taxjar", etc.
  taxTransactionId String? @map("tax_transaction_id") // External tax service reference
  taxBreakdown     Json?   @map("tax_breakdown") // Detailed tax calculation

  // Dates
  issuedAt   DateTime? @map("issued_at") // When sent to customer
  dueAt      DateTime? @map("due_at")
  scheduleAt DateTime? @map("schedule_at")
  finalizeAt DateTime? @map("finalize_at")
  paidAt     DateTime? @map("paid_at")

  // Customer communication
  notes         String? @db.Text // Internal notes
  customerNotes String? @map("customer_notes") @db.Text // Customer-facing notes
  metadata      Json?

  // Exchange rate for multi-currency
  exchangeRate Int?    @map("exchange_rate")
  baseCurrency String? @map("base_currency") // Org's base currency

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  customer     Customer?     @relation(fields: [orgId, customerId], references: [orgId, id])
  order        Order?        @relation(fields: [orgId, orderId], references: [orgId, id])
  subscription Subscription? @relation(fields: [orgId, subscriptionId], references: [orgId, id])

  lineItems   InvoiceLineItem[]
  creditNotes CreditNote[]
  payments    Payment[]
  history     InvoiceHistory[]
  documents   Document[]

  @@id([orgId, id])
  @@unique([orgId, sequenceId, docNumber])
  @@index([orgId, status])
  @@index([orgId, customerId])
  @@index([orgId, orderId])
  @@index([orgId, subscriptionId])
  @@index([orgId, dueAt])
  @@index([orgId, issuedAt])
  @@index([orgId, invoiceType])
  @@map("invoices")
}

// ===== INVOICE LINE ITEMS =====
model InvoiceLineItem {
  orgId     String @map("org_id")
  invoiceId String @map("invoice_id")
  id        String @default(cuid())

  productId String? @map("product_id")
  variantId String? @map("variant_id")
  priceId   String? @map("price_id")

  // Product/service details
  description String
  category    String? // Manual category for custom items

  // Pricing
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Int     @map("unit_price")
  lineTotal Int     @map("line_total")

  // Discounts
  discountType  String? @map("discount_type") // "percentage", "fixed"
  discountValue Int?    @map("discount_value")
  discountTotal Int     @default(0) @map("discount_total")

  // Tax (calculated by external service)
  taxCode   String? @map("tax_code") // Tax classification
  taxRate   Int?    @map("tax_rate")
  taxAmount Int?    @map("tax_amount")
  taxExempt Boolean @default(false) @map("tax_exempt")

  // Organization
  seq Int? // Display sequence on invoice

  // Metadata
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [orgId, invoiceId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, invoiceId, id])
  @@index([orgId, productId])
  @@index([orgId, category])
  @@map("invoice_line_items")
}

// ===== CREDIT NOTES =====
model CreditNote {
  orgId String @map("org_id")
  id    String @default(cuid())

  // Document identity
  sequenceId String @map("sequence_id")
  docNumber  String @map("doc_number") // CN-001

  // Reference to original invoice
  invoiceId String? @map("invoice_id")

  // Credit details
  reason     CreditNoteReason
  reasonNote String?          @map("reason_note") @db.Text

  // Financial
  currency  String @default("USD")
  amount    Int
  taxAmount Int?   @map("tax_amount")

  // Status
  status    String    @default("issued") // "draft", "issued", "applied"
  appliedAt DateTime? @map("applied_at")

  // Metadata
  notes    String? @db.Text
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice   Invoice?             @relation(fields: [orgId, invoiceId], references: [orgId, id])
  lineItems CreditNoteLineItem[]
  documents Document[]

  @@id([orgId, id])
  @@unique([orgId, sequenceId, docNumber])
  @@index([orgId, invoiceId])
  @@index([orgId, status])
  @@map("credit_notes")
}

model CreditNoteLineItem {
  orgId        String @map("org_id")
  creditNoteId String @map("credit_note_id")
  id           String @default(cuid())

  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Int     @map("unit_price")
  amount      Int
  taxAmount   Int?    @map("tax_amount")

  createdAt DateTime @default(now()) @map("created_at")

  creditNote CreditNote @relation(fields: [orgId, creditNoteId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, creditNoteId, id])
  @@map("credit_note_line_items")
}

// ===== AUDIT TRAIL =====
model InvoiceHistory {
  orgId     String @map("org_id")
  id        String @default(cuid())
  invoiceId String @map("invoice_id")

  // Change details
  action   String // "created", "sent", "paid", "voided", "updated"
  field    String? // Which field changed
  oldValue Json?   @map("old_value")
  newValue Json?   @map("new_value")

  // Context
  userId    String? @map("user_id")
  userEmail String? @map("user_email")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  // Additional context
  reason   String? // Why the change was made
  metadata Json?

  timestamp DateTime @default(now())

  invoice Invoice @relation(fields: [orgId, invoiceId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, id])
  @@index([orgId, invoiceId, timestamp])
  @@index([orgId, action, timestamp])
  @@map("invoice_history")
}

// ===== DOCUMENT STORAGE =====
model Document {
  orgId        String  @map("org_id")
  id           String  @default(cuid())
  invoiceId    String? @map("invoice_id")
  creditNoteId String? @map("credit_note_id")

  // File details
  filename     String
  originalName String @map("original_name")
  contentType  String @map("content_type")
  size         Int // Bytes

  // Storage
  storageProvider String  @map("storage_provider") // "s3", "gcs", "local"
  storageKey      String  @map("storage_key") // S3 key, file path, etc.
  url             String? // Public URL if applicable

  // Document type
  type    String  @map("type") // "pdf", "html", "attachment", "logo"
  purpose String? @map("purpose") // "invoice_pdf", "invoice_html", "company_logo", "attachment"

  // Security
  isPublic    Boolean @default(false) @map("is_public")
  accessToken String? @map("access_token")

  metadata  Json?    @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice    Invoice?    @relation(fields: [orgId, invoiceId], references: [orgId, id])
  creditNote CreditNote? @relation(fields: [orgId, creditNoteId], references: [orgId, id])

  @@id([orgId, id])
  @@index([orgId, invoiceId])
  @@index([orgId, creditNoteId])
  @@index([orgId, type])
  @@index([orgId, purpose])
  @@map("documents")
}

model DocSequence {
  orgId     String   @map("org_id")
  id        String
  type      String   @map("type")
  value     Int      @map("value")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@index([orgId, type])
  @@map("doc_sequences")
}

// Dunning campaign tracking
model DunningCampaign {
  orgId String @map("org_id")
  id    String @default(cuid())

  // Relationships
  subscriptionId String @map("subscription_id")
  customerId     String @map("customer_id")

  // Workflow metadata
  temporalWorkflowId String  @map("temporal_workflow_id")
  temporalRunId      String  @map("temporal_run_id")
  parentWorkflowId   String? @map("parent_workflow_id")

  // Campaign details
  status               DunningStatus @default(active)
  failedAmount         Int           @map("failed_amount")
  currency             String
  initialFailureReason String?       @map("initial_failure_reason")

  // Attempt tracking
  totalAttempts       Int @default(0) @map("total_attempts")
  immediateAttempts   Int @default(0) @map("immediate_attempts")
  progressiveAttempts Int @default(0) @map("progressive_attempts")

  // Timeline
  startedAt     DateTime  @default(now()) @map("started_at")
  lastAttemptAt DateTime? @map("last_attempt_at")
  nextAttemptAt DateTime? @map("next_attempt_at")
  completedAt   DateTime? @map("completed_at")

  // Outcomes
  recoveryMethod     String?   @map("recovery_method")
  recoveredAmount    Int?      @map("recovered_amount")
  recoveredAt        DateTime? @map("recovered_at")
  finalFailureReason String?   @map("final_failure_reason")

  // Configuration snapshot
  configSnapshot Json? @map("config_snapshot")

  // Metadata
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  subscription   Subscription           @relation(fields: [orgId, subscriptionId], references: [orgId, id])
  customer       Customer               @relation(fields: [orgId, customerId], references: [orgId, id])
  attempts       DunningAttempt[]
  communications DunningCommunication[]
  tokens         PaymentUpdateToken[]
  org            Org                    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("dunning_campaigns")
}

enum DunningStatus {
  active
  paused
  recovered
  failed
  cancelled
  expired
}

// Individual payment retry attempts
model DunningAttempt {
  orgId String @map("org_id")
  id    String @default(cuid())

  // Relationships
  dunningCampaignId String @map("dunning_campaign_id")
  subscriptionId    String @map("subscription_id")

  // Attempt details
  attemptNumber Int                @map("attempt_number")
  attemptType   DunningAttemptType @map("attempt_type")

  // Payment details
  amount          Int
  currency        String
  paymentMethodId String? @map("payment_method_id")

  // Results
  status            PaymentStatus
  failureReason     String?       @map("failure_reason")
  failureCode       String?       @map("failure_code")
  processorResponse Json?         @map("processor_response")

  // Performance metrics
  processingTimeMs Int?      @map("processing_time_ms")
  attemptedAt      DateTime  @default(now()) @map("attempted_at")
  completedAt      DateTime? @map("completed_at")

  // Context
  triggeredBy String? @map("triggered_by")
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  campaign DunningCampaign @relation(fields: [orgId, dunningCampaignId], references: [orgId, id])

  @@id([orgId, id])
  @@map("dunning_attempts")
}

enum DunningAttemptType {
  immediate
  progressive
  manual
  triggered
}

// Customer communications during dunning
model DunningCommunication {
  orgId String @map("org_id")
  id    String @default(cuid())

  // Relationships
  dunningCampaignId String @map("dunning_campaign_id")
  customerId        String @map("customer_id")

  // Communication details
  channel       CommunicationChannel
  templateId    String               @map("template_id")
  attemptNumber Int                  @map("attempt_number")

  // Content
  subject             String?
  contentPreview      String? @map("content_preview")
  personalizationData Json?   @map("personalization_data")

  // Delivery tracking
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  openedAt    DateTime? @map("opened_at")
  clickedAt   DateTime? @map("clicked_at")
  bouncedAt   DateTime? @map("bounced_at")

  // Provider details
  provider          String
  providerMessageId String? @map("provider_message_id")
  providerResponse  Json?   @map("provider_response")

  // Status
  status        CommunicationStatus @default(pending)
  failureReason String?             @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  campaign DunningCampaign @relation(fields: [orgId, dunningCampaignId], references: [orgId, id])
  customer Customer        @relation(fields: [orgId, customerId], references: [orgId, id])

  @@id([orgId, id])
  @@map("dunning_communications")
}

enum CommunicationChannel {
  email
  sms
  push
  webhook
  in_app
}

enum CommunicationStatus {
  pending
  sent
  delivered
  failed
  bounced
}

// Secure payment update tokens
model PaymentUpdateToken {
  orgId   String @map("org_id")
  tokenId String @map("token_id")

  // Relationships
  subscriptionId    String  @map("subscription_id")
  customerId        String  @map("customer_id")
  dunningCampaignId String? @map("dunning_campaign_id")

  // Token data
  tokenData Json   @map("token_data")
  signature String

  // Security & usage
  expiresAt DateTime    @map("expires_at")
  maxUses   Int         @default(5) @map("max_uses")
  usedCount Int         @default(0) @map("used_count")
  status    TokenStatus @default(active)

  // Allowed actions
  allowedActions Json @map("allowed_actions")

  // Admin generation tracking
  adminGenerated Boolean @default(false) @map("admin_generated")
  adminUserId    String? @map("admin_user_id")
  adminReason    String? @map("admin_reason")
  adminNotes     String? @map("admin_notes")

  // Audit trail
  createdBy  String    @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  lastUsedIp String?   @map("last_used_ip")

  // Relationships
  subscription Subscription        @relation(fields: [orgId, subscriptionId], references: [orgId, id])
  customer     Customer            @relation(fields: [orgId, customerId], references: [orgId, id])
  campaign     DunningCampaign?    @relation(fields: [orgId, dunningCampaignId], references: [orgId, id])
  usageHistory PaymentTokenUsage[]

  @@id([orgId, tokenId])
  @@map("payment_update_tokens")
}

enum TokenStatus {
  active
  expired
  revoked
  max_uses_reached
}

// Token usage tracking
model PaymentTokenUsage {
  orgId       String   @map("org_id")
  tokenId     String   @map("token_id")
  usedAt      DateTime @default(now()) @map("used_at")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  actionTaken String?  @map("action_taken")
  success     Boolean?

  // Relationships
  token PaymentUpdateToken @relation(fields: [orgId, tokenId], references: [orgId, tokenId])

  @@id([orgId, tokenId, usedAt])
  @@map("payment_token_usage")
}

// Dunning configuration
model DunningConfiguration {
  orgId String @map("org_id")
  id    String @default(cuid())

  // Configuration hierarchy
  name        String
  description String?
  priority    Int     @default(0)

  // Targeting rules
  appliesTo   DunningConfigScope @default(organization) @map("applies_to")
  targetRules Json?              @map("target_rules")

  // The actual configuration
  config Json

  // Status and testing
  status           ConfigStatus @default(active)
  isAbTest         Boolean      @default(false) @map("is_ab_test")
  abTestPercentage Decimal?     @map("ab_test_percentage")

  // Metadata
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("dunning_configurations")
}

enum DunningConfigScope {
  organization
  customer_segment
  subscription_tier
  customer
  ab_test
}

enum ConfigStatus {
  active
  inactive
  archived
}

// Analytics tables
model DunningAnalyticsDaily {
  orgId String   @map("org_id")
  date  DateTime @db.Date

  // Volume metrics
  campaignsStarted   Int @default(0) @map("campaigns_started")
  campaignsCompleted Int @default(0) @map("campaigns_completed")
  totalAttempts      Int @default(0) @map("total_attempts")

  // Recovery metrics
  immediateRecoveries   Int @default(0) @map("immediate_recoveries")
  progressiveRecoveries Int @default(0) @map("progressive_recoveries")
  manualRecoveries      Int @default(0) @map("manual_recoveries")
  totalRecoveries       Int @default(0) @map("total_recoveries")

  // Financial metrics
  amountAtRisk    Int @default(0) @map("amount_at_risk")
  amountRecovered Int @default(0) @map("amount_recovered")
  amountLost      Int @default(0) @map("amount_lost")

  // Communication metrics
  emailsSent          Int @default(0) @map("emails_sent")
  smsSent             Int @default(0) @map("sms_sent")
  totalCommunications Int @default(0) @map("total_communications")

  // Performance metrics
  avgRecoveryTimeHours  Decimal? @map("avg_recovery_time_hours")
  avgAttemptsToRecovery Decimal? @map("avg_attempts_to_recovery")

  // Segmentation
  customerSegment       String? @map("customer_segment")
  subscriptionTier      String? @map("subscription_tier")
  failureReasonCategory String? @map("failure_reason_category")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([orgId, date])
  @@map("dunning_analytics_daily")
}

// Customer dunning history summary
model CustomerDunningHistory {
  orgId      String @map("org_id")
  customerId String @map("customer_id")

  // Lifetime stats
  totalDunningCampaigns Int @default(0) @map("total_dunning_campaigns")
  successfulRecoveries  Int @default(0) @map("successful_recoveries")
  failedCampaigns       Int @default(0) @map("failed_campaigns")

  // Financial impact
  totalAmountAtRisk    Int @default(0) @map("total_amount_at_risk")
  totalAmountRecovered Int @default(0) @map("total_amount_recovered")
  totalAmountLost      Int @default(0) @map("total_amount_lost")

  // Behavior patterns
  avgRecoveryTimeHours    Decimal?              @map("avg_recovery_time_hours")
  preferredRecoveryMethod String?               @map("preferred_recovery_method")
  mostResponsiveChannel   CommunicationChannel? @map("most_responsive_channel")

  // Risk scoring
  paymentReliabilityScore Decimal? @map("payment_reliability_score")
  dunningRiskTier         String?  @map("dunning_risk_tier")

  // Dates
  firstDunningAt DateTime? @map("first_dunning_at")
  lastDunningAt  DateTime? @map("last_dunning_at")
  lastRecoveryAt DateTime? @map("last_recovery_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  customer Customer @relation(fields: [orgId, customerId], references: [orgId, id])

  @@id([orgId, customerId])
  @@map("customer_dunning_history")
}
