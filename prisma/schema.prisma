// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgStatus {
  active
  trial
  demo
  inactive
  deleted
}

model ApiKey {
  orgId     String   @map("org_id")
  id        String   @default(cuid())
  key       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("api_keys")
}

model Org {
  id           String         @id
  country      String
  status       OrgStatus      @default(active)
  name         String
  description  String?
  metadata     Json?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  users        UserOrg[]
  Session      Session[]
  Variant      Variant[]
  Price        Price[]
  Order        Order[]
  Customer     Customer[]
  Subscription Subscription[]
  Payment      Payment[]
  Setting      Setting[]
  OrderItem    OrderItem[]
  ApiKey       ApiKey[]

  @@map("orgs")
}

model Gateway {
  orgId  String  @map("org_id")
  id     String
  name   String
  pspId  String  @map("psp_id")
  active Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@id([orgId, id])
  @@map("gateways")
}

model Setting {
  orgId     String @map("org_id")
  parentId  String @map("parent_id")
  id        String
  valueType String @map("value_type")
  value     Json

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, parentId, id])
  @@map("settings")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  UserOrg   UserOrg[]

  @@map("users")
}

model UserOrg {
  userId String @map("user_id")
  orgId  String @map("org_id")

  user User @relation(fields: [userId], references: [id])
  org  Org  @relation(fields: [orgId], references: [id])

  role Role @default(user)

  @@id([userId, orgId])
  @@map("user_orgs")
}

enum Role {
  owner
  admin
  user
}

model Cart {
  orgId String @map("org_id")
  id    String @default(cuid())

  data     Json?
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  order     Order[]

  @@id([orgId, id])
  @@map("carts")
}

model Product {
  orgId String @map("org_id")
  id    String @default(cuid())

  name        String
  description String?

  metadata Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  Variant   Variant[]

  @@id([orgId, id])
  @@map("products")
}

model Variant {
  orgId String @map("org_id")
  id    String @default(cuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [orgId, productId], references: [orgId, id], onDelete: Cascade)

  name        String
  description String?

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  Price     Price[]

  org       Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  OrderItem OrderItem[]

  @@id([orgId, id])
  @@map("variants")
}

model Price {
  orgId String @map("org_id")
  id    String @default(cuid())

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [orgId, variantId], references: [orgId, id], onDelete: Cascade)

  category PriceCategory
  scheme   PriceScheme

  label String?

  currency  String
  unitPrice Int    @map("unit_price")

  cycles             Int?
  billingInterval    BillingInterval? @map("billing_interval")
  billingIntervalQty Int?             @map("billing_interval_qty")

  trialInterval    BillingInterval? @map("trial_interval")
  trialIntervalQty Int?             @map("trial_interval_qty")

  minPrice       Int? @map("min_price")
  suggestedPrice Int? @map("suggested_price")

  taxCode String? @map("tax_code")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("prices")
}

enum PriceCategory {
  one_time
  subscription
  free
  variable
}

enum PriceScheme {
  fixed
  tiered
  volume
  graduated
}

enum BillingInterval {
  none
  minute
  hour
  day
  week
  month
  year
}

model Session {
  orgId String @map("org_id")
  id    String @default(cuid())

  cartId String? @map("cart_id")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("sessions")
}

model Order {
  orgId      String      @map("org_id")
  id         String      @default(cuid())
  customerId String      @map("customer_id")
  customer   Customer    @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Restrict)
  status     OrderStatus

  reference String

  sessionId String @map("session_id")

  currency String
  total    Int

  metadata Json

  items         OrderItem[]
  subscriptions Subscription[]
  payments      Payment[]

  cartId String @map("cart_id")
  cart   Cart   @relation(fields: [orgId, cartId], references: [orgId, id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("orders")
}

enum OrderStatus {
  pending
  failed
  refunded
  partial_refund
  completed
  expired
  cancelled
  fraudulent
}

model OrderItem {
  orgId String @map("org_id")
  id    String @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id], onDelete: Cascade)

  productId String @map("product_id")
  priceId   String @map("price_id")

  description String
  quantity    Int

  subTotal      Int @default(0) @map("sub_total")
  total         Int @default(0)
  taxTotal      Int @default(0) @map("tax_total")
  discountTotal Int @default(0) @map("discount_total")

  metadata Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Variant Variant? @relation(fields: [orgId, variantId], references: [orgId, id])

  variantId    String?        @map("variant_id")
  Subscription Subscription[]

  @@id([orgId, id])
  @@map("order_items")
}

model Customer {
  orgId String @map("org_id")
  id    String @default(cuid())

  email          String
  firstName      String? @map("first_name")
  lastName       String? @map("last_name")
  phone          String?
  billingAddress Json?   @map("billing_address")

  metadata               Json?
  defaultPaymentMethodId String?        @map("default_payment_method_id")
  defaultPaymentMethod   PaymentMethod? @relation(name: "dpm", fields: [orgId, defaultPaymentMethodId], references: [orgId, id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders         Order[]
  paymentMethods PaymentMethod[]  @relation(name: "pmc")
  subscriptions  Subscription[]
  cohorts        CustomerCohort[]
  org            Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id], map: "customer_primary_key")
  @@unique([orgId, email])
  @@index([orgId, email])
  @@map("customers")
}

model Cohort {
  orgId     String           @map("org_id")
  id        String           @default(cuid())
  name      String
  type      String           @default("signup")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  customers CustomerCohort[]

  @@id([orgId, id], map: "cohort_primary_key")
  @@map("cohorts")
}

model CustomerCohort {
  orgId       String   @map("org_id")
  customerId  String   @map("customer_id")
  cohortId    String   @map("cohort_id")
  cohortValue String   @map("cohort_value")
  joinedAt    DateTime @default(now()) @map("joined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)
  cohort   Cohort   @relation(fields: [orgId, cohortId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, customerId, cohortId])
  @@map("customer_cohorts")
}

model PaymentMethod {
  orgId String @map("org_id")
  id    String @default(cuid())

  status     PaymentMethodStatus @default(active)
  psp        String
  name       String?
  customerId String              @map("customer_id")
  customer   Customer            @relation(name: "pmc", fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)

  billingAddress Json?          @map("billing_address")
  details        Json?
  type           String
  token          String
  metadata       Json?
  expireAt       DateTime?      @map("expire_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  subscriptions  Subscription[]
  Customer       Customer[]     @relation(name: "dpm")

  @@id([orgId, id], map: "paymentmethod_pk")
  @@map("payment_methods")
}

enum PaymentMethodStatus {
  active
  expired
}

model Subscription {
  orgId String @map("org_id")
  id    String @default(cuid())

  pspId String @map("psp_id")

  status SubscriptionStatus

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  orderItemId String    @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orgId, orderItemId], references: [orgId, id])

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [orgId, customerId], references: [orgId, id])

  paymentMethodId String?        @map("payment_method_id")
  paymentMethod   PaymentMethod? @relation(fields: [orgId, paymentMethodId], references: [orgId, id])

  startDate          DateTime?       @map("start_date")
  endDate            DateTime?       @map("end_date")
  billingInterval    BillingInterval @map("billing_interval")
  billingIntervalQty Int             @map("billing_interval_qty")
  cycles             Int
  billingAnchor      Int             @map("billing_anchor")
  trialEndsAt        DateTime?       @map("trial_ends_at")
  cancelAt           DateTime?       @map("cancel_at")
  endsAt             DateTime?       @map("ends_at")
  lastCharge         DateTime?       @map("last_charge")
  renewsAt           DateTime?       @map("renews_at")
  currentPeriodStart DateTime?       @map("current_period_start")
  currentPeriodEnd   DateTime?       @map("current_period_end")

  retries   Int?
  nextRetry DateTime? @map("next_retry")

  currency String
  amount   Int

  metadata Json

  cyclesProcessed Int       @map("cycles_processed")
  totalRevenue    Int       @map("total_revenue")
  cancelledAt     DateTime? @map("cancelled_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  payments  Payment[]

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  trial
  active
  retry
  past_due
  paused
  unpaid
  cancelled
  pending
  expired
  completed
}

model Payment {
  orgId String @map("org_id")
  id    String @default(cuid())

  psp       String  @map("psp")
  pspId     String? @map("psp_id")
  reference String  @default("") @map("reference")
  recurring Boolean @default(false)

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  subscriptionId String?       @map("subscription_id")
  subscription   Subscription? @relation(fields: [orgId, subscriptionId], references: [orgId, id])

  amount   Int
  currency String

  status PaymentStatus

  psp_fee      Int
  platform_fee Int
  net_amount   Int

  refunded_amount Int @default(0) @map("refunded_amount")

  metadata Json?

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org     Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@id([orgId, id])
  @@map("payments")
}

enum PaymentStatus {
  pending
  failed
  succeeded
  refunded
  partial_refund
  cancelled
  expired
  fraudulent
}

model Refund {
  orgId         String   @map("org_id")
  id            String   @default(cuid())
  psp_refund_id String?  @map("psp_refund_id")
  paymentId     String   @map("payment_id")
  payment       Payment  @relation(fields: [orgId, paymentId], references: [orgId, id], onDelete: Cascade)
  amount        Int
  currency      String
  reason        String?
  refunded_at   DateTime @map("refunded_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@map("refunds")
}

model IdempotencyKey {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id, expiresAt])
  @@map("idempotency_keys")
}

model WebhookSubscription {
  orgId     String   @map("org_id")
  id        String   @id @default(cuid())
  events    String[]
  url       String
  secret    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("webhook_subscriptions")
}
