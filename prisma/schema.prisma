// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgStatus {
  active
  inactive
  deleted
}

model Org {
  id           String         @id
  country      String
  status       OrgStatus      @default(active)
  name         String
  description  String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  users        UserOrg[]
  Session      Session[]
  Variant      Variant[]
  Price        Price[]
  Order        Order[]
  Customer     Customer[]
  Subscription Subscription[]
  Payment      Payment[]
  Setting      Setting[]
  OrderItem    OrderItem[]

  @@map("orgs")
}

model Setting {
  orgId     String @map("org_id")
  parentId  String @map("parent_id")
  id        String
  valueType String @map("value_type")
  value     Json

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, parentId, id])
  @@map("settings")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  UserOrg   UserOrg[]

  @@map("users")
}

model UserOrg {
  userId String @map("user_id")
  orgId  String @map("org_id")

  user User @relation(fields: [userId], references: [id])
  org  Org  @relation(fields: [orgId], references: [id])

  role Role @default(user)

  @@id([userId, orgId])
  @@map("user_orgs")
}

enum Role {
  owner
  admin
  user
}

model Cart {
  orgId String @map("org_id")
  id    String @default(cuid())

  data     Json?
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  order     Order[]

  @@id([orgId, id])
  @@map("carts")
}

model Product {
  orgId String @map("org_id")
  id    String @default(cuid())

  name        String
  description String?

  metadata Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  Variant   Variant[]

  @@id([orgId, id])
  @@map("products")
}

model Variant {
  orgId String @map("org_id")
  id    String @default(cuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [orgId, productId], references: [orgId, id])

  name        String
  description String?

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  Price     Price[]

  org       Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  OrderItem OrderItem[]

  @@id([orgId, id])
  @@map("variants")
}

model Price {
  orgId String @map("org_id")
  id    String @default(cuid())

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [orgId, variantId], references: [orgId, id])

  category PriceCategory
  scheme   PriceScheme

  currency  String
  unitPrice Int    @map("unit_price")

  cycles             Int?
  billingInterval    BillingInterval? @map("billing_interval")
  billingIntervalQty Int?             @map("billing_interval_qty")

  trialInterval    BillingInterval? @map("trial_interval")
  trialIntervalQty Int?             @map("trial_interval_qty")

  minPrice       Int? @map("min_price")
  suggestedPrice Int? @map("suggested_price")

  taxCode String? @map("tax_code")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("prices")
}

enum PriceCategory {
  one_time
  subscription
  free
  variable
}

enum PriceScheme {
  fixed
  tiered
  volume
  graduated
}

enum BillingInterval {
  none
  minute
  hour
  day
  week
  month
  year
}

model Session {
  orgId String @map("org_id")
  id    String @default(cuid())

  cartId String? @map("cart_id")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("sessions")
}

model Order {
  orgId      String      @map("org_id")
  id         String      @default(cuid())
  customerId String      @map("customer_id")
  customer   Customer    @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Restrict)
  status     OrderStatus

  reference String

  sessionId String @map("session_id")

  currency String
  total    Int

  metadata Json

  items         OrderItem[]
  subscriptions Subscription[]
  payments      Payment[]

  cartId String @map("cart_id")
  cart   Cart   @relation(fields: [orgId, cartId], references: [orgId, id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("orders")
}

enum OrderStatus {
  pending
  failed
  refunded
  partial_refund
  completed
  expired
  cancelled
  fraudulent
}

model OrderItem {
  orgId String @map("org_id")
  id    String @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id], onDelete: Cascade)

  priceId String @map("price_id")

  description String
  quantity    Int

  metadata Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org          Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Variant      Variant?       @relation(fields: [variantOrgId, variantId], references: [orgId, id])
  variantOrgId String?
  variantId    String?
  Subscription Subscription[]

  @@id([orgId, id])
  @@map("order_items")
}

model Customer {
  orgId String @map("org_id")
  id    String @default(cuid())

  email String
  name  String?

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders Order[]

  org            Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  paymentMethods PaymentMethod[]
  Subscription   Subscription[]

  @@id([orgId, id], map: "customer_primary_key")
  @@map("customers")
}

model PaymentMethod {
  orgId String @map("org_id")
  id    String @default(cuid())

  psp        String
  name       String?
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)

  isDefault Boolean @map("is_default")

  billingAddress Json?  @map("billing_address")
  details        Json?
  type           String
  token          String

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  subscriptions Subscription[]

  @@id([orgId, id], map: "paymentmethod_pk")
  @@map("payment_methods")
}

model Subscription {
  orgId String @map("org_id")
  id    String @default(cuid())

  pspId String @map("psp_id")

  status SubscriptionStatus

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  orderItemId String    @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orgId, orderItemId], references: [orgId, id])

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [orgId, customerId], references: [orgId, id])

  paymentMethodId String?        @map("payment_method_id")
  paymentMethod   PaymentMethod? @relation(fields: [orgId, paymentMethodId], references: [orgId, id])

  startDate          DateTime?       @map("start_date")
  endDate            DateTime?       @map("end_date")
  billingInterval    BillingInterval @map("billing_interval")
  billingIntervalQty Int             @map("billing_interval_qty")
  cycles             Int
  billingAnchor      Int             @map("billing_anchor")
  trialEndsAt        DateTime?       @map("trial_ends_at")
  cancelAt           DateTime?       @map("cancel_at")
  endsAt             DateTime?       @map("ends_at")
  lastCharge         DateTime?       @map("last_charge")
  renewsAt           DateTime?       @map("renews_at")
  currentPeriodStart DateTime?       @map("current_period_start")
  currentPeriodEnd   DateTime?       @map("current_period_end")

  retries   Int?
  nextRetry DateTime? @map("next_retry")

  currency String
  amount   Int

  metadata Json

  cyclesProcessed Int       @map("cycles_processed")
  totalRevenue    Int       @map("total_revenue")
  cancelledAt     DateTime? @map("cancelled_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  payments  Payment[]

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  trial
  active
  retry
  past_due
  paused
  unpaid
  cancelled
  pending
  expired
  completed
}

model Payment {
  orgId String @map("org_id")
  id    String @default(cuid())

  pspId     String @map("psp_id")
  reference String @default("") @map("reference")

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  subscriptionId String?       @map("subscription_id")
  subscription   Subscription? @relation(fields: [orgId, subscriptionId], references: [orgId, id])

  amount   Int
  currency String

  status PaymentStatus

  psp_fee      Int
  platform_fee Int
  net_amount   Int

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@unique([orgId, pspId])
  @@map("payments")
}

enum PaymentStatus {
  pending
  failed
  succeeded
  refunded
  partial_refund
  cancelled
  expired
  fraudulent
}

model IdempotencyKey {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id, expiresAt])
  @@map("idempotency_keys")
}

model WebhookSubscription {
  orgId     String   @map("org_id")
  id        String   @id @default(cuid())
  events    String[]
  url       String
  secret    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("webhook_subscriptions")
}
