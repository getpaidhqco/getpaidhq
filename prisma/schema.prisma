// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgStatus {
  active
  trial
  demo
  inactive
  deleted
}

enum InvoiceStatus {
  draft // Mutable, can be modified
  sent // Immutable, delivered to customer
  paid // Payment received
  overdue // Past due date
  cancelled // Cancelled before payment
  refunded // Fully refunded via credit notes
}

enum CreditNoteReason {
  correction // Pricing/calculation error
  cancellation // Order cancelled
  refund // Product/service return
  adjustment // Discount applied
  tax_adjustment // Tax correction
}

enum InvoiceType {
  initial // First purchase invoice (links to order)
  recurring // Regular subscription billing (links to subscription)
  usage // Usage-based charges over plan limits
  adjustment // Proration, credits, billing corrections
  setup // One-time setup/implementation fees
  cancellation // Early termination or final charges
  refund // Refund processing invoices
}

enum InvoiceHistoryAction {
  created // Invoice initially created
  updated // Invoice details modified (draft only)
  sent // Invoice sent to customer
  viewed // Customer viewed invoice
  paid // Payment received
  partial_paid // Partial payment received
  overdue // Invoice became overdue
  reminded // Payment reminder sent
  voided // Invoice cancelled/voided
  credited // Credit note applied
  refunded // Payment refunded
  disputed // Customer disputed invoice
  adjusted // Manual adjustment made
}

enum DocumentType {
  invoice // Standard invoice for payment
  proforma // Proforma invoice (quote/estimate)
  quote // Formal quote/proposal
  receipt // Payment receipt
  statement // Account statement
}

model ApiKey {
  orgId     String   @map("org_id")
  id        String   @default(cuid())
  key       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("api_keys")
}

model Org {
  id            String          @id
  country       String
  status        OrgStatus       @default(active)
  name          String
  timezone      String          @default("UTC")
  metadata      Json?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  users         UserOrg[]
  Session       Session[]
  Variant       Variant[]
  Price         Price[]
  Order         Order[]
  Customer      Customer[]
  Subscription  Subscription[]
  Payment       Payment[]
  Setting       Setting[]
  OrderItem     OrderItem[]
  ApiKey        ApiKey[]
  MetadataStore MetadataStore[]

  @@map("orgs")
}

model Gateway {
  orgId  String  @map("org_id")
  id     String
  name   String
  pspId  String  @map("psp_id")
  active Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@id([orgId, id])
  @@map("gateways")
}

model Setting {
  orgId     String @map("org_id")
  parentId  String @map("parent_id")
  id        String
  valueType String @map("value_type")
  value     Json

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, parentId, id])
  @@map("settings")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  UserOrg   UserOrg[]

  @@map("users")
}

model UserOrg {
  userId String @map("user_id")
  orgId  String @map("org_id")

  user User @relation(fields: [userId], references: [id])
  org  Org  @relation(fields: [orgId], references: [id])

  role Role @default(user)

  @@id([userId, orgId])
  @@map("user_orgs")
}

enum Role {
  owner
  admin
  user
}

model Cart {
  orgId String @map("org_id")
  id    String @default(cuid())

  data     Json?
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  order     Order[]

  @@id([orgId, id])
  @@map("carts")
}

model Product {
  orgId String @map("org_id")
  id    String @default(cuid())

  name        String
  description String?

  metadata Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  Variant   Variant[]

  @@id([orgId, id])
  @@map("products")
}

model Variant {
  orgId String @map("org_id")
  id    String @default(cuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [orgId, productId], references: [orgId, id], onDelete: Cascade)

  name        String
  description String?

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  Price     Price[]

  org       Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  OrderItem OrderItem[]

  @@id([orgId, id])
  @@map("variants")
}

model Price {
  orgId String @map("org_id")
  id    String @default(cuid())

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [orgId, variantId], references: [orgId, id], onDelete: Cascade)

  category PriceCategory
  scheme   PriceScheme

  label String?

  currency  String
  unitPrice Int    @map("unit_price")

  cycles             Int?
  billingInterval    BillingInterval? @map("billing_interval")
  billingIntervalQty Int?             @map("billing_interval_qty")

  trialInterval    BillingInterval? @map("trial_interval")
  trialIntervalQty Int?             @map("trial_interval_qty")

  minPrice       Int? @map("min_price")
  suggestedPrice Int? @map("suggested_price")

  taxCode String? @map("tax_code")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("prices")
}

enum PriceCategory {
  one_time
  subscription
  free
  variable
}

enum PriceScheme {
  fixed
  tiered
  volume
  graduated
}

enum BillingInterval {
  none
  minute
  hour
  day
  week
  month
  year
}

model Session {
  orgId String @map("org_id")
  id    String @default(cuid())

  cartId String? @map("cart_id")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, id])
  @@map("sessions")
}

model Order {
  orgId      String      @map("org_id")
  id         String      @default(cuid())
  customerId String      @map("customer_id")
  customer   Customer    @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Restrict)
  status     OrderStatus

  reference String

  sessionId String @map("session_id")

  currency String
  total    Int

  metadata Json

  items         OrderItem[]
  subscriptions Subscription[]
  payments      Payment[]

  cartId String @map("cart_id")
  cart   Cart   @relation(fields: [orgId, cartId], references: [orgId, id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Invoice Invoice[]

  @@id([orgId, id])
  @@map("orders")
}

enum OrderStatus {
  pending
  failed
  refunded
  partial_refund
  completed
  expired
  cancelled
  fraudulent
}

model OrderItem {
  orgId String @map("org_id")
  id    String @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id], onDelete: Cascade)

  productId String @map("product_id")
  priceId   String @map("price_id")

  description String
  quantity    Decimal @db.Decimal(10, 3)

  subTotal      Int @default(0) @map("sub_total")
  total         Int @default(0)
  taxTotal      Int @default(0) @map("tax_total")
  discountTotal Int @default(0) @map("discount_total")

  metadata Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Variant Variant? @relation(fields: [orgId, variantId], references: [orgId, id])

  variantId    String?        @map("variant_id")
  Subscription Subscription[]

  @@id([orgId, id])
  @@map("order_items")
}

model Customer {
  orgId String @map("org_id")
  id    String @default(cuid())

  email          String
  firstName      String? @map("first_name")
  lastName       String? @map("last_name")
  phone          String?
  billingAddress Json?   @map("billing_address")

  metadata               Json?
  defaultPaymentMethodId String?        @map("default_payment_method_id")
  defaultPaymentMethod   PaymentMethod? @relation(name: "dpm", fields: [orgId, defaultPaymentMethodId], references: [orgId, id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders         Order[]
  paymentMethods PaymentMethod[]  @relation(name: "pmc")
  subscriptions  Subscription[]
  cohorts        CustomerCohort[]
  org            Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Invoice        Invoice[]

  @@id([orgId, id], map: "customer_primary_key")
  @@unique([orgId, email])
  @@index([orgId, email])
  @@map("customers")
}

model Cohort {
  orgId     String           @map("org_id")
  id        String           @default(cuid())
  name      String
  type      String           @default("signup")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  customers CustomerCohort[]

  @@id([orgId, id], map: "cohort_primary_key")
  @@map("cohorts")
}

model CustomerCohort {
  orgId       String   @map("org_id")
  customerId  String   @map("customer_id")
  cohortId    String   @map("cohort_id")
  cohortValue String   @map("cohort_value")
  joinedAt    DateTime @default(now()) @map("joined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)
  cohort   Cohort   @relation(fields: [orgId, cohortId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, customerId, cohortId])
  @@map("customer_cohorts")
}

model PaymentMethod {
  orgId String @map("org_id")
  id    String @default(cuid())

  status     PaymentMethodStatus @default(active)
  psp        String
  name       String?
  customerId String              @map("customer_id")
  customer   Customer            @relation(name: "pmc", fields: [orgId, customerId], references: [orgId, id], onDelete: Cascade)

  billingAddress Json?          @map("billing_address")
  details        Json?
  type           String
  token          String
  metadata       Json?
  expireAt       DateTime?      @map("expire_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  subscriptions  Subscription[]
  Customer       Customer[]     @relation(name: "dpm")

  @@id([orgId, id], map: "paymentmethod_pk")
  @@map("payment_methods")
}

enum PaymentMethodStatus {
  active
  expired
}

model Subscription {
  orgId String @map("org_id")
  id    String @default(cuid())

  pspId String @map("psp_id")

  status SubscriptionStatus

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  orderItemId String    @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orgId, orderItemId], references: [orgId, id])

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [orgId, customerId], references: [orgId, id])

  paymentMethodId String?        @map("payment_method_id")
  paymentMethod   PaymentMethod? @relation(fields: [orgId, paymentMethodId], references: [orgId, id])

  startDate          DateTime?       @map("start_date")
  endDate            DateTime?       @map("end_date")
  billingInterval    BillingInterval @map("billing_interval")
  billingIntervalQty Int             @map("billing_interval_qty")
  cycles             Int
  billingAnchor      Int             @map("billing_anchor")
  trialEndsAt        DateTime?       @map("trial_ends_at")
  cancelAt           DateTime?       @map("cancel_at")
  endsAt             DateTime?       @map("ends_at")
  lastCharge         DateTime?       @map("last_charge")
  renewsAt           DateTime?       @map("renews_at")
  currentPeriodStart DateTime?       @map("current_period_start")
  currentPeriodEnd   DateTime?       @map("current_period_end")

  retries   Int?
  nextRetry DateTime? @map("next_retry")

  currency String
  amount   Int

  metadata Json

  cyclesProcessed Int       @map("cycles_processed")
  totalRevenue    Int       @map("total_revenue")
  cancelledAt     DateTime? @map("cancelled_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  payments  Payment[]

  org     Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  Invoice Invoice[]

  @@id([orgId, id])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  trial
  active
  retry
  past_due
  paused
  unpaid
  cancelled
  pending
  expired
  completed
}

model Payment {
  orgId String @map("org_id")
  id    String @default(cuid())

  psp       String  @map("psp")
  pspId     String? @map("psp_id")
  reference String  @default("") @map("reference")
  recurring Boolean @default(false)

  orderId String @map("order_id")
  order   Order  @relation(fields: [orgId, orderId], references: [orgId, id])

  invoiceId String?  @map("invoice_id")
  Invoice   Invoice? @relation(fields: [orgId, invoiceId], references: [orgId, id])

  subscriptionId String?       @map("subscription_id")
  subscription   Subscription? @relation(fields: [orgId, subscriptionId], references: [orgId, id])

  amount   Int
  currency String

  status PaymentStatus

  pspFee      Int @map("psp_fee")
  platformFee Int @map("platform_fee")
  netAmount   Int @map("net_amount")

  refundedAmount Int @default(0) @map("refunded_amount")

  metadata Json?

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org     Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@id([orgId, id])
  @@index([orgId, invoiceId])
  @@index([orgId, subscriptionId])
  @@map("payments")
}

enum PaymentStatus {
  pending
  failed
  succeeded
  refunded
  partial_refund
  cancelled
  expired
  fraudulent
}

enum RefundStatus {
  pending
  completed
  error
}

model Refund {
  orgId         String       @map("org_id")
  id            String       @default(cuid())
  psp_refund_id String?      @map("psp_refund_id")
  paymentId     String       @map("payment_id")
  payment       Payment      @relation(fields: [orgId, paymentId], references: [orgId, id], onDelete: Cascade)
  amount        Int
  currency      String
  reason        String?
  status        RefundStatus @default(pending)
  refunded_at   DateTime     @map("refunded_at")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@id([orgId, id])
  @@map("refunds")
}

model IdempotencyKey {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id, expiresAt])
  @@map("idempotency_keys")
}

model WebhookSubscription {
  orgId     String   @map("org_id")
  id        String   @id @default(cuid())
  events    String[]
  url       String
  secret    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("webhook_subscriptions")
}

model MetadataStore {
  orgId      String   @map("org_id")
  parentId   String   @map("parent_id")
  parentType String?  @map("parent_type")
  key        String
  value      String
  namespace  String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, parentId, key])
  @@index([orgId, key, value], name: "metadata_store_org_id_key_value_idx")
  @@index([orgId, parentId], name: "metadata_store_org_id_parent_id_idx")
  @@index([orgId, parentType, key], name: "metadata_store_org_id_parent_type_key_idx")
  @@index([parentId], name: "metadata_store_parent_id_idx")
  @@map("metadata_store")
}

model Invoice {
  orgId String @map("org_id")
  id    String @default(cuid())

  // References - hybrid approach
  customerId     String? @map("customer_id")
  orderId        String? @map("order_id") // For initial purchase invoices
  subscriptionId String? @map("subscription_id") // For recurring invoices

  // Document identity
  sequenceId  String       @map("sequence_id") // From doc sequence
  docNumber   String       @map("doc_number") // Human readable: INV-001
  type        DocumentType @default(invoice) // "invoice", "proforma", "quote"
  invoiceType InvoiceType  @map("invoice_type") // Why this invoice exists

  // Status and immutability
  status      InvoiceStatus @default(draft)
  isImmutable Boolean       @default(false) @map("is_immutable")

  // Financial data
  currency      String @default("USD")
  subTotal      Int    @map("sub_total")
  taxTotal      Int    @map("tax_total")
  discountTotal Int    @default(0) @map("discount_total")
  total         Int
  amountPaid    Int    @default(0) @map("amount_paid")
  amountDue     Int    @map("amount_due")

  // Tax integration
  taxProvider      String? @map("tax_provider") // "avalara", "taxjar", etc.
  taxTransactionId String? @map("tax_transaction_id") // External tax service reference
  taxBreakdown     Json?   @map("tax_breakdown") // Detailed tax calculation

  // Dates
  issuedAt   DateTime? @map("issued_at") // When sent to customer
  dueAt      DateTime? @map("due_at")
  scheduleAt DateTime? @map("schedule_at")
  finalizeAt DateTime? @map("finalize_at")
  paidAt     DateTime? @map("paid_at")

  // Customer communication
  notes         String? @db.Text // Internal notes
  customerNotes String? @map("customer_notes") @db.Text // Customer-facing notes
  metadata      Json?

  // Exchange rate for multi-currency
  exchangeRate Int?    @map("exchange_rate")
  baseCurrency String? @map("base_currency") // Org's base currency

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  customer     Customer?     @relation(fields: [orgId, customerId], references: [orgId, id])
  order        Order?        @relation(fields: [orgId, orderId], references: [orgId, id])
  subscription Subscription? @relation(fields: [orgId, subscriptionId], references: [orgId, id])

  lineItems   InvoiceLineItem[]
  creditNotes CreditNote[]
  payments    Payment[]
  history     InvoiceHistory[]
  documents   Document[]

  @@id([orgId, id])
  @@unique([orgId, sequenceId, docNumber])
  @@index([orgId, status])
  @@index([orgId, customerId])
  @@index([orgId, orderId])
  @@index([orgId, subscriptionId])
  @@index([orgId, dueAt])
  @@index([orgId, issuedAt])
  @@index([orgId, invoiceType])
  @@map("invoices")
}

// ===== INVOICE LINE ITEMS =====
model InvoiceLineItem {
  orgId     String @map("org_id")
  invoiceId String @map("invoice_id")
  id        String @default(cuid())

  productId String? @map("product_id")
  variantId String? @map("variant_id")
  priceId   String? @map("price_id")

  // Product/service details
  description String
  category    String? // Manual category for custom items

  // Pricing
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Int     @map("unit_price")
  lineTotal Int     @map("line_total")

  // Discounts
  discountType  String? @map("discount_type") // "percentage", "fixed"
  discountValue Int?    @map("discount_value")
  discountTotal Int     @default(0) @map("discount_total")

  // Tax (calculated by external service)
  taxCode   String? @map("tax_code") // Tax classification
  taxRate   Int?    @map("tax_rate")
  taxAmount Int?    @map("tax_amount")
  taxExempt Boolean @default(false) @map("tax_exempt")

  // Organization
  seq Int? // Display sequence on invoice

  // Metadata
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [orgId, invoiceId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, invoiceId, id])
  @@index([orgId, productId])
  @@index([orgId, category])
  @@map("invoice_line_items")
}

// ===== CREDIT NOTES =====
model CreditNote {
  orgId String @map("org_id")
  id    String @default(cuid())

  // Document identity
  sequenceId String @map("sequence_id")
  docNumber  String @map("doc_number") // CN-001

  // Reference to original invoice
  invoiceId String? @map("invoice_id")

  // Credit details
  reason     CreditNoteReason
  reasonNote String?          @map("reason_note") @db.Text

  // Financial
  currency  String @default("USD")
  amount    Int
  taxAmount Int?   @map("tax_amount")

  // Status
  status    String    @default("issued") // "draft", "issued", "applied"
  appliedAt DateTime? @map("applied_at")

  // Metadata
  notes    String? @db.Text
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice   Invoice?             @relation(fields: [orgId, invoiceId], references: [orgId, id])
  lineItems CreditNoteLineItem[]
  documents Document[]

  @@id([orgId, id])
  @@unique([orgId, sequenceId, docNumber])
  @@index([orgId, invoiceId])
  @@index([orgId, status])
  @@map("credit_notes")
}

model CreditNoteLineItem {
  orgId        String @map("org_id")
  creditNoteId String @map("credit_note_id")
  id           String @default(cuid())

  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Int     @map("unit_price")
  amount      Int
  taxAmount   Int?    @map("tax_amount")

  createdAt DateTime @default(now()) @map("created_at")

  creditNote CreditNote @relation(fields: [orgId, creditNoteId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, creditNoteId, id])
  @@map("credit_note_line_items")
}

// ===== AUDIT TRAIL =====
model InvoiceHistory {
  orgId     String @map("org_id")
  id        String @default(cuid())
  invoiceId String @map("invoice_id")

  // Change details
  action   String // "created", "sent", "paid", "voided", "updated"
  field    String? // Which field changed
  oldValue Json?   @map("old_value")
  newValue Json?   @map("new_value")

  // Context
  userId    String? @map("user_id")
  userEmail String? @map("user_email")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  // Additional context
  reason   String? // Why the change was made
  metadata Json?

  timestamp DateTime @default(now())

  invoice Invoice @relation(fields: [orgId, invoiceId], references: [orgId, id], onDelete: Cascade)

  @@id([orgId, id])
  @@index([orgId, invoiceId, timestamp])
  @@index([orgId, action, timestamp])
  @@map("invoice_history")
}

// ===== DOCUMENT STORAGE =====
model Document {
  orgId        String  @map("org_id")
  id           String  @default(cuid())
  invoiceId    String? @map("invoice_id")
  creditNoteId String? @map("credit_note_id")

  // File details
  filename     String
  originalName String @map("original_name")
  contentType  String @map("content_type")
  size         Int // Bytes

  // Storage
  storageProvider String  @map("storage_provider") // "s3", "gcs", "local"
  storageKey      String  @map("storage_key") // S3 key, file path, etc.
  url             String? // Public URL if applicable

  // Document type
  type    String // "pdf", "html", "attachment", "logo"
  purpose String? // "invoice_pdf", "invoice_html", "company_logo", "attachment"

  // Security
  isPublic    Boolean @default(false) @map("is_public")
  accessToken String? @map("access_token")

  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice    Invoice?    @relation(fields: [orgId, invoiceId], references: [orgId, id])
  creditNote CreditNote? @relation(fields: [orgId, creditNoteId], references: [orgId, id])

  @@id([orgId, id])
  @@index([orgId, invoiceId])
  @@index([orgId, creditNoteId])
  @@index([orgId, type])
  @@index([orgId, purpose])
  @@map("documents")
}

model DocSequence {
  org_id     String
  id         String
  type       String
  value      Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@id([org_id, id])
  @@index([org_id, type])
  @@map("doc_sequences")
}
