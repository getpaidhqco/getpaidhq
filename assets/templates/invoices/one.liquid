<body class="m-auto p-8 min-h-screen flex flex-col">
<div class="flex-grow ">

    <div class="flex items-center justify-between space-x-5">
        <div class="flex items-start space-x-5">
            <div class="flex-shrink-0">
                <div class="relative">
                    <img class="w-64"
                         src="{{ logo_url }}" alt="">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                </div>
            </div>

        </div>
        <div class="mt-6 flex flex-col-reverse justify-stretch space-y-4 space-y-reverse flex-row-reverse justify-end space-x-reverse space-y-0 space-x-3 mt-0 flex-row space-x-3">
            <p class="text-4xl text-gray-700">

                {% if type == "credit_note" %}
                {{ labels.credit_heading | default: "CREDIT" }}
                {% else %}
                {{ labels.heading | default: "TAX INVOICE" }}
                {% endif %}

            </p>
        </div>
    </div>

    <div class="mt-16 flex justify-between">
        <div class="leading-7">
            <h1 class="text-lg font-bold text-gray-900">{{ business.business_name }}</h1>
            <p class="text-sm  text-gray-500">{{ business.address1 }}</p>
            <p class="text-sm  text-gray-500">{{ business.address2 }}</p>
            <p class="text-sm  text-gray-500">{{ business.city }}</p>
            <p class="text-sm  text-gray-500">{{ business.postal_code }}</p>
            <p class="text-sm  text-gray-500">{{ business.country }}</p>
        </div>

        <div class="">
            <dl class="">
                <div class="grid grid-cols-2 gap-2">
                    <dt class="text-sm font-medium text-gray-500">
                        {% if type == "credit_note" %}
                        {{ labels.credit_number | default: "Credit #" }}
                        {% else %}
                        {{ labels.invoice_number | default: "Invoice #" }}
                        {% endif %}
                    </dt>
                    <dd class="text-sm font-medium text-gray-900 mt-0">
                        {{ document_number }}
                    </dd>
                </div>
            </dl>
            <dl class="">
                <div class="grid grid-cols-2 gap-2">
                    <dt class="text-sm font-medium text-gray-500">
                        {{ labels.created_date | default: "Created Date" }}
                    </dt>
                    <dd class="text-sm text-gray-900 mt-0">
                        {{ create_date }}
                    </dd>
                </div>
            </dl>
            <dl class="">
                <div class="grid grid-cols-2 gap-2">
                    <dt class="text-sm font-medium text-gray-500">
                        {{ labels.due_date | default: "Due Date" }}
                    </dt>
                    <dd class="text-sm text-gray-900 mt-0">
                        {{ due_date }}
                    </dd>
                </div>
            </dl>
            <dl class="">
                <div class="grid grid-cols-2 gap-2">
                    <dt class="text-sm font-medium text-gray-500">
                        {{ labels.vat_number | default: "VAT #" }}
                    </dt>
                    <dd class="text-sm text-gray-900 mt-0">
                        {{ business.vat_number }}
                    </dd>
                </div>
            </dl>


            {% if type == "credit_note" %}
            <dl class="">
                <div class="grid grid-cols-2 gap-2">
                    <dt class="text-sm font-medium text-gray-500">
                        {{ labels.related_document | default: "Related Document" }}
                    </dt>
                    <dd class="text-sm text-gray-900 mt-0">
                        {{ related_document }}
                    </dd>
                </div>
            </dl>
            {% endif %}


        </div>

    </div>

    <div class="mt-4 w-full border-t border-gray-300">
    </div>

    <div class="mt-4 flex justify-between">
        <div class="">
            <p class="font-bold text-gray-900">{{ labels.to | default: "To" }} </p>
            <p class="text-sm  text-gray-500">{{ customer.name }}</p>
            <p class="text-sm  text-gray-500">{{ customer.email }}</p>
            <p class="text-sm  text-gray-500">{{ customer.business_name }}</p>
            <p class="text-sm  text-gray-500">{{ customer.vat_number }}</p>
            <p class="text-sm  text-gray-500">{{ customer.address1 }}</p>
            <p class="text-sm  text-gray-500">{{ customer.address2 }}</p>
            <p class="text-sm  text-gray-500">{{ customer.address3 }}</p>
            <p class="text-sm  text-gray-500">{{ customer.city }}</p>
            <p class="text-sm  text-gray-500">{{ customer.postal_code }}</p>
            <p class="text-sm  text-gray-500">{{ customer.region }}</p>
            <p class="text-sm  text-gray-500">{{ customer.country }}</p>

        </div>

        <div class="">

        </div>

    </div>


    <div class="mt-8 w-full border-t border-gray-300">
    </div>


    <div class="flex flex-col">
        <div class="-my-2 overflow-x-auto -mx-6 -mx-8">
            <div class="py-2 align-middle inline-block min-w-full  px-8">
                <div class="overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200 border-b border-gray-200">
                        <thead class="">
                        <tr>
                            <th scope="col"
                                class=" py-2 text-left text-xs font-medium text-gray-900 uppercase tracking-wider">
                                {{ labels.description | default: "Description" }}
                            </th>
                            <th scope="col"
                                class=" py-3 text-left text-xs font-medium text-gray-900 uppercase tracking-wider text-right">
                                {{ labels.quantity | default: "Qty" }}
                            </th>
                            <th scope="col"
                                class=" py-3 text-left text-xs font-medium text-gray-900 uppercase tracking-wider text-right">
                                {{ labels.unit_price | default: "Unit Price" }}
                            </th>
                            <th scope="col"
                                class=" py-3 text-left text-xs font-medium text-gray-900 uppercase tracking-wider text-right">
                                {{ labels.total_ex_vat | default: "Total" }}
                            </th>
                        </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                        {% for item in items %}
                        <tr>
                            <td class=" py-2 whitespace-nowrap text-sm font-medium text-gray-900">
                                {{ item.name }}
                            </td>
                            <td class=" py-2 whitespace-nowrap text-sm font-medium text-gray-900 text-right">
                                {{ item.quantity }}
                            </td>
                            <td class=" py-2 whitespace-nowrap text-sm font-medium text-gray-900  text-right">
                                {{ item.unit_price }}
                            </td>
                            <td class=" py-4 whitespace-nowrap text-sm text-gray-900 text-right px-2  text-right">
                                {{ currency_symbol }}{{ item.total }}
                            </td>
                        </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                    <div class="flex justify-end">
                        <dl class="w-1/3 py-2 space-y-1">
                            <div class="flex items-center justify-between px-2">
                                <dt class="leading-6 text-sm text-gray-500">
                                    {{ labels.subtotal | default: "Subtotal" }}
                                </dt>
                                <dd class="text-sm font-medium text-gray-900">
                                    {{ currency_symbol }}{{ sub_total }}
                                </dd>
                            </div>


                            <div class="flex items-center justify-between px-2">
                                <dt class="leading-6 text-sm text-gray-500">
                                    {{ labels.discount | default: "Discount" }}
                                </dt>
                                <dd class="text-sm font-medium text-gray-900">
                                    {{ currency_symbol }}{{ discount_total }}
                                </dd>
                            </div>


                            {%if has_item_tax %}
                            {% for item in items %}
                            {%if item.tax.name %}
                            <div class="flex items-center justify-between px-2">
                                <dt class="leading-6 text-sm text-gray-500">
                                    {{ item.tax.name }} ({{item.tax.rate}}%)
                                </dt>
                                <dd class="text-sm font-medium text-gray-900">
                                    {{ currency_symbol }}{{ item.tax_total }}
                                </dd>
                            </div>
                            {%endif%}
                            {%endfor%}

                            {% else %}
                            <div class="flex items-center justify-between px-2">
                                <dt class="leading-6 text-sm text-gray-500">
                                    {{ labels.tax_type | default: "Tax" }}
                                </dt>
                                <dd class="text-base font-medium text-gray-900">
                                    {{ currency_symbol }}{{ tax_total }}
                                </dd>
                            </div>
                            {%if exchange_rate.rate %}
                            <div class="flex items-center justify-between px-2">
                                <dt class="leading-6 text-sm text-gray-500">

                                </dt>
                                <dd class="text-xs font-light text-gray-900">
                                    ({{exchange_rate.local_currency}} {{exchange_rate.tax_total}})
                                </dd>
                            </div>
                            {%endif%}
                            {%endif%}


                            <div class="flex items-center justify-between border border-gray-400 p-2">
                                <dt class="leading-6 text-base font-medium">
                                    {{ labels.total | default: "Total" }}
                                </dt>
                                <dd class="text-base font-medium text-gray-900">
                                    {{ currency_symbol }}{{ total }}
                                </dd>
                            </div>


                        </dl>
                    </div>

                </div>

            </div>

        </div>
    </div>


    <div class="mt-4 w-full border-t border-gray-300">
    </div>


    <div class="">
        <p class="font-bold text-gray-900">{{ labels.payment_information | default: "Payment Information" }} </p>

        {% for payment in payments %}
        <dd class="flex flex-wrap">
            <div class="">
                <p class="text-gray-900">{{ payment.currency }}{{ payment.amount }}</p>
                <p class="text-gray-600">{{ payment.created_at }}</p>
                <p class="text-gray-900">{{ payment.payment_type }} {%if payment.processor_id%}({{ payment.processor_id
                    }}){%endif%}</p>
            </div>
        </dd>
        {% endfor %}
    </div>

</div>
<p class="text-base text-gray-400">
    {{ notes }}
</p>
{%if exchange_rate.rate %}
<p class="text-xs font-light text-gray-400">
        {{ labels.exchange_rate | default: "Exchange Rate" }} ({{currency}}/{{ exchange_rate.local_currency }}): {{ exchange_rate.rate }}
</p>
{%endif%}
<div class="mt-12  pt-8">
    <p class="text-base text-gray-400">
        {{ footer_text }}
    </p>
</div>


</body>
</html>
