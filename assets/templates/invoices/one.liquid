{% for item in items %}
{%if item.tax.name %}
{% assign has_item_tax = true %}
{%endif%}
{%endfor%}


<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
    <title>Invoice</title>

    <style>
