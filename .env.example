# Copy to `.env` and fill in. Every variable the app reads is listed here.
# `lib.NewEnv()` loads `.env` via godotenv and binds these names via viper.

# ─── Runtime ───────────────────────────────────────────────────────────────────
ENV=
LOG_LEVEL=
GETPAIDHQ_LOG_LEVEL=
LOG_FORMAT=
LOG_OUTPUT=

# ─── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=
SERVER_HOST=
MCP_SSE_PORT=
# Comma-separated CORS allowlist. Use "*" only in development —
# wildcard disables AllowCredentials. Empty rejects all cross-origin requests.
ALLOWED_ORIGINS=

# Comma-separated CIDRs allowed to set X-Forwarded-For / X-Real-IP. Empty =
# ignore those headers and trust RemoteAddr only (safe default). Set to your
# load balancer / WAF range in prod, e.g. "10.0.0.0/8,127.0.0.1/32". Also used
# to key per-IP rate limiting below.
TRUSTED_PROXIES=

# Per-client (per-IP) API rate limiting. RATE_LIMIT_RPS is the sustained
# requests/sec; set to 0 to DISABLE rate limiting entirely. RATE_LIMIT_BURST is
# the token-bucket capacity (momentary spike); <= 0 defaults to RATE_LIMIT_RPS.
# Enabled by default (20/40); tune to your traffic profile.
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# ─── Workflow engine ───────────────────────────────────────────────────────────
# Set to "hatchet" (default) or "temporal". Each adapter has parity over
# subscription + dunning + outgoing-webhook workflows; only one runs at a time.
WORKFLOW_ENGINE=
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_HOST_PORT=
HATCHET_CLIENT_NAMESPACE=
HATCHET_CLIENT_TLS_STRATEGY=
TEMPORAL_HOST=
TEMPORAL_NAMESPACE=
TEMPORAL_TASK_QUEUE=

# ─── Database ──────────────────────────────────────────────────────────────────
# Shared Postgres exposed on host port 6432 by docker-compose.
DATABASE_URL=
REPORTING_DATABASE_URL=
USAGE_DATABASE_URL=

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
TOKEN_EXPIRY=
CLERK_SECRET=
CLERK_DOMAIN=

# Cognito — compiled but not the default authenticator
COGNITO_CLIENT_ID=
COGNITO_POOL_ID=
COGNITO_REGION=

# ─── Authorization (Cedar) ─────────────────────────────────────────────────────
CEDAR_POLICY=

# ─── Payment gateways ──────────────────────────────────────────────────────────
PAYSTACK_API_KEY=
PAYSTACK_SECRET=

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=
LOOPS_API_KEY=
RESEND_API_KEY=
EMAIL_FROM_EMAIL=

# ─── Token vault ───────────────────────────────────────────────────────────────
# TOKEN_VAULT_TYPE: aes (local) | aws_secrets_manager (hosted)
TOKEN_VAULT_TYPE=
TOKEN_VAULT_AES_KEY=
TOKEN_VAULT_AWS_REGION=
TOKEN_VAULT_AWS_PATH=

# ─── Pub/Sub (NATS adapter) ────────────────────────────────────────────────────
PUBSUB_PROVIDER=
# External NATS server URL. The docker stack exposes one on localhost:10422
# (host port remapped into the 10xxx band). The app retries the initial connect
# and reconnects.
NATS_URL=nats://localhost:10422

# ─── Cache (Redis) ─────────────────────────────────────────────────────────────
# host:port of Redis. The docker stack exposes one on localhost:10379. Backs the
# cache adapter AND the distributed rate limiter — when set, rate limiting is
# enforced cluster-wide; when empty, it falls back to a per-instance limiter.
REDIS_HOST=localhost:10379
REDIS_PASSWORD=

# ─── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=
