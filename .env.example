# Copy to `.env` and fill in. Every variable the app reads is listed here.
# `lib.NewEnv()` loads `.env` via godotenv. Most names exist in two forms — the
# `GPHQ_`-prefixed legacy form and the un-prefixed canonical form the Go app
# actually reads via viper. Keep both in sync unless you know what you're doing.

# ─── Runtime ───────────────────────────────────────────────────────────────────
GPHQ_ENV=
ENV=
LOG_LEVEL=
GPHQ_PAYLOOP_LOG_LEVEL=
PAYLOOP_LOG_LEVEL=
GPHQ_LOG_FORMAT=
LOG_OUTPUT=

# ─── Server ────────────────────────────────────────────────────────────────────
GPHQ_SERVER_PORT=
SERVER_PORT=
GPHQ_SERVER_HOST=
GPHQ_MCP_SSE_PORT=

# ─── Workflow engine (Hatchet only while we're local-only) ─────────────────────
WORKFLOW_ENGINE=
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_HOST_PORT=
HATCHET_CLIENT_NAMESPACE=
HATCHET_CLIENT_TLS_STRATEGY=

# ─── Database ──────────────────────────────────────────────────────────────────
# Shared Postgres exposed on host port 6432 by docker-compose.
GPHQ_DATABASE_URL=
DATABASE_URL=
GPHQ_REPORTING_DATABASE_URL=
REPORTING_DATABASE_URL=
GPHQ_USAGE_DATABASE_URL=

# ─── Auth ──────────────────────────────────────────────────────────────────────
GPHQ_JWT_SECRET=
JWT_SECRET=
GPHQ_TOKEN_EXPIRY=
GPHQ_CLERK_SECRET=
CLERK_SECRET=
GPHQ_CLERK_DOMAIN=

# Cognito — compiled but not the default authenticator
GPHQ_COGNITO_CLIENT_ID=
COGNITO_CLIENT_ID=
GPHQ_COGNITO_POOL_ID=
COGNITO_POOL_ID=
GPHQ_COGNITO_REGION=
COGNITO_REGION=

# ─── Authorization (Cedar) ─────────────────────────────────────────────────────
GPHQ_CEDAR_POLICY=
CEDAR_POLICY=

# ─── Payment gateways ──────────────────────────────────────────────────────────
GPHQ_PAYSTACK_API_KEY=
PAYSTACK_API_KEY=
PAYSTACK_SECRET=

# ─── Email ─────────────────────────────────────────────────────────────────────
GPHQ_EMAIL_PROVIDER=
LOOPS_API_KEY=
RESEND_API_KEY=
GPHQ_EMAIL_FROM_EMAIL=

# ─── Token vault ───────────────────────────────────────────────────────────────
# GPHQ_TOKEN_VAULT_TYPE: aes (local) | aws_secrets_manager (hosted)
GPHQ_TOKEN_VAULT_TYPE=
GPHQ_TOKEN_VAULT_AES_KEY=
GPHQ_TOKEN_VAULT_AWS_REGION=
GPHQ_TOKEN_VAULT_AWS_PATH=

# ─── Pub/Sub (NATS adapter) ────────────────────────────────────────────────────
GPHQ_PUBSUB_PROVIDER=

# ─── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PASSWORD=

# ─── SQS / event publishing ────────────────────────────────────────────────────
GPHQ_SQS_QUEUE_URL=
GPHQ_SQS_ACCESS_KEY_ID=
GPHQ_SQS_SECRET_ACCESS_KEY=
GPHQ_AWS_REGION=
GPHQ_EVENT_PUBLISHER=

# ─── S3 ────────────────────────────────────────────────────────────────────────
GPHQ_S3_BUCKET=
GPHQ_S3_REGION=

# ─── Temporal (legacy — Go code is still compiled but unused) ──────────────────
TEMPORAL_HOST=
