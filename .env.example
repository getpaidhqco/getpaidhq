# Copy to `.env` and fill in. Every variable the app reads is listed here.
# `lib.NewEnv()` loads `.env` via godotenv and binds these names via viper.

# ─── Runtime ───────────────────────────────────────────────────────────────────
ENV=
LOG_LEVEL=
GETPAIDHQ_LOG_LEVEL=
LOG_FORMAT=
LOG_OUTPUT=

# ─── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=
SERVER_HOST=
MCP_SSE_PORT=

# ─── Workflow engine (Hatchet only while we're local-only) ─────────────────────
WORKFLOW_ENGINE=
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_HOST_PORT=
HATCHET_CLIENT_NAMESPACE=
HATCHET_CLIENT_TLS_STRATEGY=

# ─── Database ──────────────────────────────────────────────────────────────────
# Shared Postgres exposed on host port 6432 by docker-compose.
DATABASE_URL=
REPORTING_DATABASE_URL=
USAGE_DATABASE_URL=

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
TOKEN_EXPIRY=
CLERK_SECRET=
CLERK_DOMAIN=

# Cognito — compiled but not the default authenticator
COGNITO_CLIENT_ID=
COGNITO_POOL_ID=
COGNITO_REGION=

# ─── Authorization (Cedar) ─────────────────────────────────────────────────────
CEDAR_POLICY=

# ─── Payment gateways ──────────────────────────────────────────────────────────
PAYSTACK_API_KEY=
PAYSTACK_SECRET=

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=
LOOPS_API_KEY=
RESEND_API_KEY=
EMAIL_FROM_EMAIL=

# ─── Token vault ───────────────────────────────────────────────────────────────
# TOKEN_VAULT_TYPE: aes (local) | aws_secrets_manager (hosted)
TOKEN_VAULT_TYPE=
TOKEN_VAULT_AES_KEY=
TOKEN_VAULT_AWS_REGION=
TOKEN_VAULT_AWS_PATH=

# ─── Pub/Sub (NATS adapter) ────────────────────────────────────────────────────
PUBSUB_PROVIDER=

# ─── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PASSWORD=

# ─── SQS / event publishing ────────────────────────────────────────────────────
SQS_QUEUE_URL=
SQS_ACCESS_KEY_ID=
SQS_SECRET_ACCESS_KEY=
AWS_REGION=
EVENT_PUBLISHER=

# ─── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=

# ─── Temporal (legacy — Go code is still compiled but unused) ──────────────────
TEMPORAL_HOST=
