# Copy to `.env` and fill in. Every variable the app reads is listed here.
# `lib.NewEnv()` loads `.env` via godotenv and binds these names via viper.

# ─── Runtime ───────────────────────────────────────────────────────────────────
ENV=
LOG_LEVEL=
# App log level: debug | info (default) | warn | error.
GETPAIDHQ_LOG_LEVEL=
# pretty (colored, human-readable) | text (logfmt) | json. Default: pretty when
# ENV is development/local, json otherwise.
LOG_FORMAT=
LOG_OUTPUT=
# GORM SQL log level, independent of the app level: silent | error | warn
# (default — slow queries + errors only) | info (every query).
GORM_LOG_LEVEL=

# ─── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=
SERVER_HOST=
MCP_SSE_PORT=
# Comma-separated CORS allowlist. Use "*" only in development —
# wildcard disables AllowCredentials. Empty rejects all cross-origin requests.
ALLOWED_ORIGINS=

# Comma-separated CIDRs allowed to set X-Forwarded-For / X-Real-IP. Empty =
# ignore those headers and trust RemoteAddr only (safe default). Set to your
# load balancer / WAF range in prod, e.g. "10.0.0.0/8,127.0.0.1/32". Also used
# to key per-IP rate limiting below.
TRUSTED_PROXIES=

# Per-client (per-IP) API rate limiting. RATE_LIMIT_RPS is the sustained
# requests/sec; set to 0 to DISABLE rate limiting entirely. RATE_LIMIT_BURST is
# the token-bucket capacity (momentary spike); <= 0 defaults to RATE_LIMIT_RPS.
# Enabled by default (20/40); tune to your traffic profile.
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# ─── Workflow engine ───────────────────────────────────────────────────────────
# Set to "hatchet" (default) or "temporal". Each adapter has parity over
# subscription + dunning + outgoing-webhook workflows; only one runs at a time.
WORKFLOW_ENGINE=
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_HOST_PORT=
HATCHET_CLIENT_NAMESPACE=
HATCHET_CLIENT_TLS_STRATEGY=
# How often the Hatchet billing sweep fires (Go duration, 1m-60m; default 5m)
HATCHET_BILLING_SWEEP_INTERVAL=5m
# Hatchet SDK client/worker log level, independent of the app level:
# debug | info | warn (default) | error.
HATCHET_LOG_LEVEL=
# Export worker task spans to the Hatchet engine's trace collector (dashboard
# trace view). Requires SERVER_OBSERVABILITY_ENABLED=true on the Hatchet
# server (set in docker/docker-compose.yml for local dev). Default false.
HATCHET_TRACING_ENABLED=
TEMPORAL_HOST=
TEMPORAL_NAMESPACE=
TEMPORAL_TASK_QUEUE=

# ─── Database ──────────────────────────────────────────────────────────────────
# Shared Postgres exposed on host port 6432 by docker-compose.
DATABASE_URL=
REPORTING_DATABASE_URL=
# Usage-event store DB (meter_events). Designed as a SEPARATE database so the usage
# firehose scales/retains independently; migrate with `make db-migrate-usage`. Empty =
# fall back to DATABASE_URL (single-Postgres local dev).
# e.g. postgres://getpaidhq:getpaidhq@localhost:10432/getpaidhq_usage?sslmode=disable
USAGE_DATABASE_URL=

# ─── Usage event store ───────────────────────────────────────────────────────────
# Backend for usage/metering events: postgres (default) | clickhouse.
# See docs/internal/clickhouse-primer.md.
USAGE_EVENT_STORE=postgres
# clickhouse-go DSN; only opened when USAGE_EVENT_STORE is clickhouse.
# e.g. clickhouse://user:pass@localhost:9000/getpaidhq_usage
CLICKHOUSE_DSN=
# Durable write path for usage events: sync (default, inline write) | jetstream
# (publish to NATS JetStream; a background consumer drains into the event store).
# jetstream requires JetStream enabled on the NATS server (docker: nats -js).
USAGE_INGEST_MODE=sync
# How many events the jetstream consumer writes per batch (min 1). Ignored for sync.
USAGE_INGEST_BATCH_SIZE=100

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
TOKEN_EXPIRY=
CLERK_SECRET=
CLERK_DOMAIN=
# Server-side secret used to HMAC API keys before storage. Required for API-key auth.
API_KEY_PEPPER=
# Base64-encoded 32-byte key for AES-256-GCM encryption of stored PSP
# credentials. Required to configure or use payment gateways.
# Generate: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=

# Cognito — compiled but not the default authenticator
COGNITO_CLIENT_ID=
COGNITO_POOL_ID=
COGNITO_REGION=

# ─── Authorization (Cedar) ─────────────────────────────────────────────────────
CEDAR_POLICY=

# ─── Payment gateways ──────────────────────────────────────────────────────────
PAYSTACK_API_KEY=
PAYSTACK_SECRET=
# Checkout.com webhook HMAC-SHA256 signing key (Cko-Signature verification).
CHECKOUT_WEBHOOK_SECRET=

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=
LOOPS_API_KEY=
RESEND_API_KEY=
EMAIL_FROM_EMAIL=

# ─── Token vault ───────────────────────────────────────────────────────────────
# TOKEN_VAULT_TYPE: aes (local) | aws_secrets_manager (hosted)
TOKEN_VAULT_TYPE=
TOKEN_VAULT_AES_KEY=
TOKEN_VAULT_AWS_REGION=
TOKEN_VAULT_AWS_PATH=

# ─── Pub/Sub (NATS adapter) ────────────────────────────────────────────────────
PUBSUB_PROVIDER=
# External NATS server URL. The docker stack exposes one on localhost:10422
# (host port remapped into the 10xxx band). The app retries the initial connect
# and reconnects.
NATS_URL=nats://localhost:10422

# ─── Cache (Redis) ─────────────────────────────────────────────────────────────
# host:port of Redis. The docker stack exposes one on localhost:10379. Backs the
# cache adapter AND the distributed rate limiter — when set, rate limiting is
# enforced cluster-wide; when empty, it falls back to a per-instance limiter.
REDIS_HOST=localhost:10379
REDIS_PASSWORD=

# ─── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=
